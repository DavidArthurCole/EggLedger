<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github" value="https://nuget.pkg.github.com/DavidArthurCole/index.json" />
  </packageSources>
  <!-- SyncKit.* is published to GitHub Packages. Local dev: set GITHUB_PACKAGES_USER +
       GITHUB_PACKAGES_PAT (a PAT with read:packages). CI injects creds via
       `dotnet nuget add source` with GITHUB_TOKEN, overriding this entry. -->
  <packageSourceCredentials>
    <github>
      <add key="Username" value="%GITHUB_PACKAGES_USER%" />
      <add key="ClearTextPassword" value="%GITHUB_PACKAGES_PAT%" />
    </github>
  </packageSourceCredentials>
  <packageSourceMapping>
    <packageSource key="github">
      <package pattern="SyncKit.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
