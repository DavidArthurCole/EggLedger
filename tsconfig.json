{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2021", "DOM"],
    "strict": true,
    "jsx": "preserve",
    "noEmit": true,
    "paths": {}
  },
  "include": ["www/src/**/*.ts", "www/src/**/*.vue", "vite.config.ts"],
  "exclude": ["node_modules", "www/dist"]
}
