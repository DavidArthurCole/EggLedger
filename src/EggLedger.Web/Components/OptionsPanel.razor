@using EggLedger.Web.Settings

@*
    Grouped settings toggles. Port of the toggle groups in
    www/src/views/SettingsView.vue + OptionsPanel.vue that survive in the browser
    build: Export, Fetch Behavior, and Display. Window/Browser and Storage groups
    are desktop-only and gated in SettingsPage, not here. Each control writes its
    Go setting key through OnSetting; the parent owns persistence + auto-sync.
*@

<div class="opt-groups">
    <section class="opt-group">
        <h2 class="opt-heading">Export</h2>
        <label class="opt-row">
            <input type="checkbox" checked="@Model.AutoExportCsv"
                   @onchange="e => SetAsync(SettingsModel.KeyAutoExportCsv, b => Model.AutoExportCsv = b, e)" />
            Auto-export CSV on fetch
        </label>
        <label class="opt-row">
            <input type="checkbox" checked="@Model.AutoExportXlsx"
                   @onchange="e => SetAsync(SettingsModel.KeyAutoExportXlsx, b => Model.AutoExportXlsx = b, e)" />
            Auto-export XLSX on fetch
        </label>
    </section>

    <section class="opt-group">
        <h2 class="opt-heading">Fetch Behavior</h2>
        <label class="opt-row">
            <input type="checkbox" checked="@Model.AutoRetry"
                   @onchange="e => SetAsync(SettingsModel.KeyRetryFailedMissions, b => Model.AutoRetry = b, e)" />
            Automatically retry missions that fail while fetching
        </label>
        <label class="opt-row">
            <input type="checkbox" checked="@Model.HideTimeoutErrors"
                   @onchange="e => SetAsync(SettingsModel.KeyHideTimeoutErrors, b => Model.HideTimeoutErrors = b, e)" />
            Hide per-mission timeout errors in the fetch log
        </label>

        <div class="opt-worker">
            <span class="opt-subheading">Parallel Download Workers</span>
            <div class="opt-worker-bars">
                @for (int i = 1; i <= SettingsModel.MaxWorkerCount; i++)
                {
                    var n = i;
                    <button type="button"
                            class="opt-worker-cell @WorkerBandClass(n) @(n > Model.WorkerCount ? "opt-worker-dim" : "")"
                            aria-label="@($"{n} workers")"
                            @onclick="() => SetWorkerAsync(n)">
                    </button>
                }
            </div>
            <div class="opt-worker-legend">
                <span class="opt-worker-safe">Safe</span>
                <span class="opt-worker-caution">Caution</span>
                <span class="opt-worker-risky">Risky</span>
            </div>
            <span class="opt-worker-value @WorkerBandClass(Model.WorkerCount)">@Model.WorkerCount</span>
            @if (!Model.WorkerCountWarningRead)
            {
                <div class="opt-worker-warn">
                    <span class="opt-worker-warn-title">Warning:</span>
                    Higher values fetch missions faster but may trigger API rate limiting.
                    Sustained use can lead to IP blocking.
                    <button type="button" class="opt-link" @onclick="DismissWorkerWarningAsync">I understand</button>
                </div>
            }
        </div>
    </section>

    <section class="opt-group">
        <h2 class="opt-heading">Display</h2>
        <label class="opt-row">
            <input type="checkbox" checked="@Model.ScreenshotSafety"
                   @onchange="e => SetAsync(SettingsModel.KeyScreenshotSafety, b => Model.ScreenshotSafety = b, e)" />
            Mask player IDs (EIDs) wherever they appear on screen
        </label>
        <label class="opt-row">
            <input type="checkbox" checked="@Model.ShowMissionProgress"
                   @onchange="e => SetAsync(SettingsModel.KeyShowMissionProgress, b => Model.ShowMissionProgress = b, e)" />
            Show individual mission progress during fetching
        </label>
        <label class="opt-row">
            <input type="checkbox" checked="@Model.CollapseOlderSections"
                   @onchange="e => SetAsync(SettingsModel.KeyCollapseOlderSections, b => Model.CollapseOlderSections = b, e)" />
            Collapse all but the most recent year section by default
        </label>
        <label class="opt-row">
            <input type="checkbox" checked="@Model.AutoRefreshMenno"
                   @onchange="e => SetAsync(SettingsModel.KeyAutoRefreshMenno, b => Model.AutoRefreshMenno = b, e)" />
            Automatically refresh Menno data once weekly
        </label>
    </section>
</div>

@code {
    /// <summary>The live settings model the page hydrated from IndexedDB.</summary>
    [Parameter, EditorRequired]
    public SettingsModel Model { get; set; } = default!;

    /// <summary>
    /// Persist callback: (key, stringValue). The page writes it to
    /// IndexedDbSettings and fires auto-sync. Invoked after the model is mutated.
    /// </summary>
    [Parameter, EditorRequired]
    public EventCallback<(string Key, string Value)> OnSetting { get; set; }

    private static string WorkerBandClass(int n) =>
        n <= 4 ? "opt-worker-band-safe" : n <= 7 ? "opt-worker-band-caution" : "opt-worker-band-risky";

    private async Task SetAsync(string key, Action<bool> apply, ChangeEventArgs e)
    {
        bool value = e.Value is bool b ? b : bool.TryParse(e.Value?.ToString(), out var parsed) && parsed;
        apply(value);
        await OnSetting.InvokeAsync((key, SettingsModel.FormatBool(value)));
    }

    private async Task SetWorkerAsync(int n)
    {
        Model.WorkerCount = SettingsModel.ClampWorkerCount(n);
        await OnSetting.InvokeAsync((SettingsModel.KeyWorkerCount, SettingsModel.FormatInt(Model.WorkerCount)));
    }

    private async Task DismissWorkerWarningAsync()
    {
        Model.WorkerCountWarningRead = true;
        await OnSetting.InvokeAsync((SettingsModel.KeyWorkerCountWarningRead, SettingsModel.FormatBool(true)));
    }
}
