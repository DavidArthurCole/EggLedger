@using EggLedger.Web.Settings

@*
    Grouped settings toggles. Port of the toggle sections in
    www/src/views/SettingsView.vue that survive in the browser build: Export,
    Fetch Behavior (incl. the worker slider), and Display. Window/Browser and
    Storage groups are desktop-only and gated in SettingsPage, not here. Each
    control writes its setting key through OnSetting; the parent owns persistence
    and auto-sync. Classes match the Vue (view-layout @apply layer).
*@

<div class="px-2 py-2 text-sm text-gray-400 bg-darker rounded-md tabular-nums overflow-auto">
    <span class="mr-0_5rem font-bold text-lg text-gray-400 ledger-underline">Export</span><br />
    <div class="mt-0_5rem">
        <input id="autoExportCsvCheckbox" type="checkbox" class="ext-opt-check mr-0_5rem"
               checked="@Model.AutoExportCsv"
               @onchange="e => SetAsync(SettingsModel.KeyAutoExportCsv, b => Model.AutoExportCsv = b, e)" />
        <label for="autoExportCsvCheckbox" class="ext-opt-label">Auto-export CSV on fetch</label>
    </div>
    <div class="mt-0_5rem">
        <input id="autoExportXlsxCheckbox" type="checkbox" class="ext-opt-check mr-0_5rem"
               checked="@Model.AutoExportXlsx"
               @onchange="e => SetAsync(SettingsModel.KeyAutoExportXlsx, b => Model.AutoExportXlsx = b, e)" />
        <label for="autoExportXlsxCheckbox" class="ext-opt-label">Auto-export XLSX on fetch</label>
    </div>
</div>

<hr class="mt-1rem mb-1rem w-full" />

<div class="px-2 py-2 text-sm text-gray-400 bg-darker rounded-md tabular-nums overflow-auto">
    <span class="mr-0_5rem font-bold text-lg text-gray-400 ledger-underline">Fetch Behavior</span><br />
    <div class="mt-0_5rem">
        <span class="section-heading">Auto-Retry Failed Missions</span><br />
        <input id="autoRetryCheckbox" type="checkbox" class="ext-opt-check mr-0_5rem"
               checked="@Model.AutoRetry"
               @onchange="e => SetAsync(SettingsModel.KeyRetryFailedMissions, b => Model.AutoRetry = b, e)" />
        <label for="autoRetryCheckbox" class="ext-opt-label">Automatically retry pulling missions that fail while fetching</label>
    </div>
    <div class="mt-0_5rem">
        <span class="section-heading">Timeout Errors</span><br />
        <input id="hideTimeoutErrorsCheckbox" type="checkbox" class="ext-opt-check mr-0_5rem"
               checked="@Model.HideTimeoutErrors"
               @onchange="e => SetAsync(SettingsModel.KeyHideTimeoutErrors, b => Model.HideTimeoutErrors = b, e)" />
        <label for="hideTimeoutErrorsCheckbox" class="ext-opt-label">Hide per-mission timeout errors in the fetch log</label>
    </div>
    <div class="mt-0_5rem">
        <span class="section-heading">Parallel Download Workers</span><br />
        <div class="mt-0_5rem pl-0_5rem">
            <div class="relative h-7 mb-1 select-none w-4/5">
                <span class="absolute top-0 text-sm font-bold font-mono -translate-x-1/2 @WorkerTextClass(Model.WorkerCount)"
                      style="left: @($"{(Model.WorkerCount - 0.5) * 10}%")">@Model.WorkerCount</span>
                <div class="absolute bottom-0 h-2.5 border-b border-l pointer-events-none opacity-70 @WorkerBorderClass(Model.WorkerCount)"
                     style="left: 0; width: @($"{(Model.WorkerCount - 0.5) * 10}%")"></div>
            </div>
            <div class="flex gap-px w-4/5 cursor-pointer">
                @for (int i = 1; i <= SettingsModel.MaxWorkerCount; i++)
                {
                    var n = i;
                    <div class="flex-1 h-4 rounded-sm @WorkerCellClass(n) @(n > Model.WorkerCount ? "opacity-20" : "")"
                         @onclick="() => SetWorkerAsync(n)"></div>
                }
            </div>
            <div class="flex text-xs mt-0_25rem select-none w-4/5">
                <span class="text-green-500 text-center" style="width: 40%">Safe</span>
                <span class="text-orange-400 text-center" style="width: 30%">Caution</span>
                <span class="text-red-500 text-center" style="width: 30%">Risky</span>
            </div>
        </div>
        @if (!Model.WorkerCountWarningRead)
        {
            <div class="mt-0_5rem pl-0_5rem text-red-700 border border-red-700 rounded-md py-2 px-3">
                <span class="font-bold ledger-underline">Warning:</span><br />
                Higher values fetch missions faster but may trigger API rate limiting.
                Sustained use of higher values can lead to IP blocking and potential further consequences.
                <br /><br />
                <button type="button" class="dismiss-btn" @onclick="DismissWorkerWarningAsync">I understand</button>
            </div>
        }
    </div>
</div>

<hr class="mt-1rem mb-1rem w-full" />

<div class="px-2 py-2 text-sm text-gray-400 bg-darker rounded-md tabular-nums overflow-auto">
    <span class="mr-0_5rem font-bold text-lg text-gray-400 ledger-underline">Display</span><br />
    <div class="mt-0_5rem">
        <span class="section-heading">Screenshot Safety</span><br />
        <input id="screenshotSafetyCheckbox" type="checkbox" class="ext-opt-check mr-0_5rem"
               checked="@Model.ScreenshotSafety"
               @onchange="e => SetAsync(SettingsModel.KeyScreenshotSafety, b => Model.ScreenshotSafety = b, e)" />
        <label for="screenshotSafetyCheckbox" class="ext-opt-label">Mask player IDs (EIDs) wherever they appear on screen</label>
    </div>
    <div class="mt-0_5rem">
        <span class="section-heading">Mission Progress Panel</span><br />
        <input id="showMissionProgressCheckbox" type="checkbox" class="ext-opt-check mr-0_5rem"
               checked="@Model.ShowMissionProgress"
               @onchange="e => SetAsync(SettingsModel.KeyShowMissionProgress, b => Model.ShowMissionProgress = b, e)" />
        <label for="showMissionProgressCheckbox" class="ext-opt-label">Show individual mission progress during fetching</label>
    </div>
    <div class="mt-0_5rem">
        <span class="section-heading">Mission Data Default Collapse</span><br />
        <input id="collapseOlderSectionsCheckbox" type="checkbox" class="ext-opt-check mr-0_5rem"
               checked="@Model.CollapseOlderSections"
               @onchange="e => SetAsync(SettingsModel.KeyCollapseOlderSections, b => Model.CollapseOlderSections = b, e)" />
        <label for="collapseOlderSectionsCheckbox" class="ext-opt-label">Collapse all but the most recent year section by default</label>
    </div>
</div>

@code {
    /// <summary>The live settings model the page hydrated from IndexedDB.</summary>
    [Parameter, EditorRequired]
    public SettingsModel Model { get; set; } = default!;

    /// <summary>
    /// Persist callback: (key, stringValue). The page writes it to
    /// IndexedDbSettings and fires auto-sync. Invoked after the model is mutated.
    /// </summary>
    [Parameter, EditorRequired]
    public EventCallback<(string Key, string Value)> OnSetting { get; set; }

    // Worker-band coloring matches the Vue: 1-4 safe (green), 5-7 caution (orange),
    // 8-10 risky (red). Bars use solid bg utilities; text/border use the lighter shade.
    private static string WorkerCellClass(int n) =>
        n <= 4 ? "bg-green-600" : n <= 7 ? "bg-orange-500" : "bg-red-600";

    private static string WorkerTextClass(int n) =>
        n <= 4 ? "text-green-400" : n <= 7 ? "text-orange-400" : "text-red-400";

    private static string WorkerBorderClass(int n) =>
        n <= 4 ? "border-green-400" : n <= 7 ? "border-orange-400" : "border-red-400";

    private async Task SetAsync(string key, Action<bool> apply, ChangeEventArgs e)
    {
        bool value = e.Value is bool b ? b : bool.TryParse(e.Value?.ToString(), out var parsed) && parsed;
        apply(value);
        await OnSetting.InvokeAsync((key, SettingsModel.FormatBool(value)));
    }

    private async Task SetWorkerAsync(int n)
    {
        Model.WorkerCount = SettingsModel.ClampWorkerCount(n);
        await OnSetting.InvokeAsync((SettingsModel.KeyWorkerCount, SettingsModel.FormatInt(Model.WorkerCount)));
    }

    private async Task DismissWorkerWarningAsync()
    {
        Model.WorkerCountWarningRead = true;
        await OnSetting.InvokeAsync((SettingsModel.KeyWorkerCountWarningRead, SettingsModel.FormatBool(true)));
    }
}
