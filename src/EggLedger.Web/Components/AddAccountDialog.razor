@using EggLedger.Domain.MissionQuery
@using EggLedger.Web.Services
@using EggLedger.Web.State
@inject AddAccountService AddAccount

@* Add-account modal. Blazor-controlled overlay (full-screen fixed backdrop + centered
   card). NOT a native <dialog>.showModal(): top-layer promotion desyncs the Blazor Server
   render tree (insertBefore/parentNode-null crashes). Backdrop click closes. *@

@if (_open)
{
<div class="fixed inset-0 z-40 flex items-center justify-center bg-black/60" @onclick="Close">
    <div class="add-account-dialog p-0 border border-gray-600 rounded-lg bg-darker text-gray-300 shadow-2xl" @onclick:stopPropagation="true">
    <div class="p-4 min-w-80">
        <h2 class="mb-3 text-sm font-bold text-gray-300">Add Account</h2>
        <form @onsubmit="Submit" @onsubmit:preventDefault>
            <input
                class="w-full box-border px-2 py-1 text-sm rounded bg-darkest border border-gray-600 text-gray-300 mb-1 focus:outline-none focus:border-blue-500"
                type="text"
                placeholder="Enter player ID (e.g. EI1234567890123456)"
                @bind="_eid"
                @bind:event="oninput"
                disabled="@_loading" />
            @if (_problem != "" && _eid.Trim() != "")
            {
                <p class="mb-1 text-xs text-yellow-500">@_problem</p>
            }
            @if (_error != "")
            {
                <p class="mb-2 text-xs text-red-500">@_error</p>
            }
            @if (_loading)
            {
                <p class="mb-2 text-xs text-gray-400">Fetching account data...</p>
            }
            <div class="flex gap-2 justify-end mt-1">
                <button type="button" class="text-xs px-3 py-1 rounded border border-gray-600 bg-transparent text-gray-400 hover:text-gray-300 disabled:opacity-50 disabled:cursor-default" disabled="@_loading" @onclick="Close">Cancel</button>
                <button type="submit" class="text-xs px-3 py-1 rounded border-none bg-privacy_blue text-white hover:bg-blue-700 disabled:opacity-50 disabled:cursor-default" disabled="@(_loading || !IsValid)">Add</button>
            </div>
        </form>
    </div>
    </div>
</div>
}

@code {
    private bool _open;
    private string _eid = "";
    private bool _loading;
    private string _error = "";

    /// <summary>Raised with the freshly added account on success.</summary>
    [Parameter]
    public EventCallback<AccountInfo> Added { get; set; }
    private string Normalized => LedgerFormatting.NormalizeEid(_eid);
    private string _problem => LedgerFormatting.EidProblem(Normalized);
    private bool IsValid => LedgerFormatting.IsEidValid(Normalized);

    public void Open()
    {
        _eid = "";
        _error = "";
        _loading = false;
        _open = true;
        StateHasChanged();
    }

    private void Close() => _open = false;

    private async Task Submit()
    {
        if (!IsValid)
        {
            return;
        }
        _loading = true;
        _error = "";
        try
        {
            var account = await AddAccount.AddAccountAsync(Normalized);
            await Added.InvokeAsync(account);
            Close();
        }
        catch (Exception e)
        {
            _error = e.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
