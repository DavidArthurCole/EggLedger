@using EggLedger.Domain.MissionQuery
@using EggLedger.Web.Services
@using EggLedger.Web.State
@inject AddAccountService AddAccount
@inject IJSRuntime Js

<dialog @ref="_dialog" class="add-account-dialog">
    <div class="dialog-body">
        <h2 class="dialog-title">Add Account</h2>
        <form @onsubmit="Submit" @onsubmit:preventDefault>
            <input
                class="eid-input"
                type="text"
                placeholder="Enter player ID (e.g. EI1234567890123456)"
                @bind="_eid"
                @bind:event="oninput"
                disabled="@_loading" />
            @if (_problem != "" && _eid.Trim() != "")
            {
                <p class="msg-warn">@_problem</p>
            }
            @if (_error != "")
            {
                <p class="msg-error">@_error</p>
            }
            @if (_loading)
            {
                <p class="msg-dim">Fetching account data...</p>
            }
            <div class="dialog-actions">
                <button type="button" class="btn-cancel" disabled="@_loading" @onclick="Close">Cancel</button>
                <button type="submit" class="btn-add" disabled="@(_loading || !IsValid)">Add</button>
            </div>
        </form>
    </div>
</dialog>

@code {
    private ElementReference _dialog;
    private string _eid = "";
    private bool _loading;
    private string _error = "";

    /// <summary>Raised with the freshly added account on success.</summary>
    [Parameter]
    public EventCallback<AccountInfo> Added { get; set; }

    private string Normalized => LedgerFormatting.NormalizeEid(_eid);
    private string _problem => LedgerFormatting.EidProblem(Normalized);
    private bool IsValid => LedgerFormatting.IsEidValid(Normalized);

    private IJSObjectReference? _module;

    private async ValueTask<IJSObjectReference> ModuleAsync() =>
        _module ??= await Js.InvokeAsync<IJSObjectReference>("import", "./_content/EggLedger.Web/js/dialog.js");

    public async Task OpenAsync()
    {
        _eid = "";
        _error = "";
        _loading = false;
        StateHasChanged();
        var module = await ModuleAsync();
        await module.InvokeVoidAsync("showModal", _dialog);
    }

    private async Task Close()
    {
        var module = await ModuleAsync();
        await module.InvokeVoidAsync("close", _dialog);
    }

    private async Task Submit()
    {
        if (!IsValid)
        {
            return;
        }
        _loading = true;
        _error = "";
        try
        {
            var account = await AddAccount.AddAccountAsync(Normalized);
            await Added.InvokeAsync(account);
            await Close();
        }
        catch (Exception e)
        {
            _error = e.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
