@* Shared "Options"-style toggle-link + dropdown panel: grows down-and-left from the
   trigger button, sized to its own content (never a guessed fixed width, so it can't
   spill past its own border), and closes on any outside click. Used by Mission Data
   and Lifetime Data. *@

<div class="relative flex-shrink-0">
    <button type="button" class="text-base toggle-link whitespace-nowrap" @onclick="Toggle">
        @ButtonText
    </button>
    @if (_open) {
        <div class="fixed inset-0 z-30" @onclick="Close"></div>
        <div class="absolute right-0 top-full mt-1 z-40 w-max max-w-[90vw] px-3 py-2 shadow-sm text-sm text-gray-400 bg-darkest border border-gray-700 rounded-md tabular-nums"
             @onclick:stopPropagation="true">
            @ChildContent
        </div>
    }
</div>

@code {
    [Parameter] public string ButtonText { get; set; } = "Options";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    private bool _open;

    private void Toggle() {
        _open = !_open;
    }

    private void Close() {
        _open = false;
    }

}
