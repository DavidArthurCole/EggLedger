@using System.Globalization
@using EggLedger.Domain.MissionPacking
@using EggLedger.Web.Missions

@* Single-mode ship display: identity + details + capacity badge, then drops.
   Hover tooltips and menno expected-drops detail are deferred. *@

<div class="text-gray-300 text-center">
    <div class="flex flex-row gap-2 mb-3 mx-auto items-center" style="width: fit-content;">
        <div class="@(Mission.IsBuggedCap ? "bugged-cap-span" : (Mission.IsDubCap ? "double-cap-span" : "")) flex items-center py-1 px-1.5 self-center"
             style="visibility: @(Mission.IsBuggedCap || Mission.IsDubCap ? "visible" : "hidden");">
            <img class="w-5 mr-0_5rem"
                 alt="@(Mission.IsBuggedCap ? "Skull Emoji" : "Artifact Crate")"
                 src="@(Mission.IsBuggedCap ? State.ContentPaths.Asset("images/skull.png") : State.ContentPaths.Asset("images/icon_afx_chest_2.png"))" />
            <span class="text-xs font-bold whitespace-nowrap">
                @(Mission.IsBuggedCap
                    ? "0.6x Capacity"
                    : Data.CapacityModifier.ToString("0.##", CultureInfo.InvariantCulture) + "x Capacity")
            </span>
        </div>

        <div class="rounded-md px-4 py-2 flex flex-col items-center justify-center" style="background: rgba(120, 128, 138, 0.12);">
            @if (!string.IsNullOrEmpty(Mission.ShipEnumString))
            {
                <img class="w-12 h-12 object-contain mb-2" src="@State.ContentPaths.Asset($"images/ships/{Mission.ShipEnumString}.png")" alt="@Mission.ShipString" />
            }
            <span class="@DurationClass">@Mission.ShipString</span>
            @if (Mission.Level > 0)
            {
                <span class="text-star text-goldenstar">@(new string('★', Mission.Level))</span>
            }
        </div>

        <div class="rounded-md px-4 py-2 flex flex-col justify-center text-left text-sm" style="background: rgba(120, 128, 138, 0.12);">
            <div>Launched: @Format(Data.LaunchDT)</div>
            <div>Returned: @Format(Data.ReturnDT)</div>
            <div>Duration: @Data.DurationStr</div>
            <div>Capacity: @Mission.Capacity</div>
            @if (HasTarget)
            {
                <div class="flex items-center gap-1 mt-1">
                    <span>Sensor Target:</span>
                    <div class="text-xs rounded-full w-max px-1.5 py-0.5 text-gray-400 bg-darkerer font-semibold">@ProperCase(Mission.Target.Replace("_", " ", StringComparison.Ordinal))</div>
                </div>
            }
        </div>
    </div>

    <DropDisplayContainer Artifacts="Data.Artifacts"
                          Stones="Data.Stones"
                          Ingredients="Data.Ingredients"
                          StoneFragments="Data.StoneFragments" />
</div>

@code {
    [Parameter]
    public ViewMissionData Data { get; set; } = new();

    private DatabaseMission Mission => Data.MissionInfo;

    private bool HasTarget =>
        Mission.Target.Length > 0 && !string.Equals(Mission.Target, "UNKNOWN", StringComparison.OrdinalIgnoreCase);

    private string DurationClass =>
        Mission.DurationType is { } d
            ? "text-duration-" + Convert.ToInt32(d, CultureInfo.InvariantCulture)
            : "text-duration-3";

    private static string Format(DateTime dt) => dt.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture);

    private static string ProperCase(string value)
    {
        var words = value.ToLowerInvariant().Split(' ');
        for (int i = 0; i < words.Length; i++)
        {
            if (words[i] is not ("of" or "the") && words[i].Length > 0)
            {
                words[i] = char.ToUpperInvariant(words[i][0]) + words[i].Substring(1);
            }
        }
        var joined = string.Join(' ', words);
        return joined.Length > 0 ? char.ToUpperInvariant(joined[0]) + joined.Substring(1) : joined;
    }
}
