@using System.Globalization
@using EggLedger.Web.Missions
@* One spec-type section: colored label "Label (totalCount)" then grouped drop icons.
   Each icon links to the artifact explorer and shows a hover tooltip (name, tier, rarity,
   count, effect string, and menno expected-drops when enabled). *@

@if (Items is { Count: > 0 }) {
    <div class="@LabelClass">
        @LabelText (@TotalCount)
    </div>
    <div class="ledger-af-repeat">
        @foreach (var item in Items) {
            <div class="mission-view-rep relative">
                <a class="@RarityBgClass(item)" target="_blank" rel="noopener" href="@ExplorerUrl(item)"
                   @onmouseenter="@(() => ShowTooltip(item))" @onmouseleave="HideTooltip">
                    <img class="h-full w-full" loading="lazy" decoding="async" alt="@item.GameName" src="@SpecPath(item)"/>
                    @if (item.Count > 1) {
                        <span class="ledger-af-count @NumToDigClass(item.Count)">@item.Count</span>
                    }
                </a>
                @if (ReferenceEquals(_hovered, item)) {
                    <div class="tooltip-floating tooltip-anchored text-sm">
                        @item.GameName (T@(item.Level + SpecPathOffset(item)))
                        @if (item.SpecType == "Artifact") {
                            <span class="text-rarity-@item.Rarity">@RarityWord(item.Rarity) </span>
                        }
                        × @item.Count
                        @if (item.SpecType is "Artifact" or "Stone") {
                            <br/>
                            var bound = BoundEffectString(item.EffectString);
                            <span>
                                @bound.Prefix<span class="text-green-500">@bound.Highlight</span>@bound.Suffix
                            </span>
                        }
                        @if (ShowExpectedDrops) {
                            <hr class="mt-0_5rem mb-0_5rem w-full"/>
                            var calc = DropCalcs(item);
                            @if (calc is null) {
                                <span class="text-red-700">Not enough data to determine drop rate.</span>
                            } else {
                                <span class="text-gray-400">
                                    <span class="text-green-500">@calc.Value.Seen.ToString("N0", CultureInfo.InvariantCulture)</span>
                                    <span> seen out of </span>
                                    <span class="text-green-500">@calc.Value.Total.ToString("N0", CultureInfo.InvariantCulture)</span>
                                    <span> drops</span><br/>
                                    <span>(Average of <span class="text-green-500">@ExpectedPerShip(item)</span> expected in this ship)</span>
                                </span>
                            }
                        }
                    </div>
                }
            </div>
        }
    </div>
    <br/>
}

@code {

    [Parameter]
    public string Type { get; set; } = "";

    [Parameter] public IReadOnlyList<DropLike>? Items { get; set; }
    [Parameter] public MissionMennoData? MennoData { get; set; }
    [Parameter] public bool ShowExpectedDrops { get; set; }

    [Parameter]
    public int MissionTotalDrops { get; set; }

    private DropLike? _hovered;

    private void ShowTooltip(DropLike item) {
        _hovered = item;
    }

    private void HideTooltip() {
        _hovered = null;
    }

    private int TotalCount {
        get {
            var sum = 0;
            if (Items is not null) {
                foreach (var i in Items) {
                    sum += i.Count;
                }
            }

            return sum;
        }
    }

    private string LabelText => Type switch {
        "artifact" => "Artifacts",
        "stone" => "Eggfinity Stones",
        "ingredient" => "Ingredients",
        "stone_fragment" => "Stone Fragments",
        _ => "Unknown"
    };

    private string LabelClass => "mission-view-div " + Type switch {
        "artifact" => "bg-blue-900",
        "stone" => "bg-fuchsia-900",
        "ingredient" or "stone_fragment" => "text-gray-400 bg-darkerer",
        _ => "bg-gray-900"
    };

    private static readonly string[] Rarities = ["Common", "Rare", "Epic", "Legendary"];

    private static string RarityWord(int rarity) {
        return rarity >= 0 && rarity < Rarities.Length ? Rarities[rarity] : "";
    }

    
    private static int SpecPathOffset(DropLike item) {
        return item.SpecType == "Stone" ? 2 : 1;
    }

    
    private static string RarityBgClass(DropLike item) {
        return item.SpecType == "Artifact" ? "ledger-af-link bg-r-" + item.Rarity : "ledger-af-link bg-r-0";
    }

    private static string ExplorerUrl(DropLike item) {
        var slug = item.Name
            .Replace("_FRAGMENT", "", StringComparison.Ordinal)
            .ToLowerInvariant()
            .Replace("_", "-", StringComparison.Ordinal);
        return $"https://wasmegg-carpet.netlify.app/artifact-explorer/#/artifact/{slug}-{item.Level + SpecPathOffset(item)}";
    }

    
    private static string NumToDigClass(int num) {
        return num switch {
            > 999999 => "w-sevendig",
            > 99999 => "w-sixdig",
            > 9999 => "w-fivedig",
            > 999 => "w-fourdig",
            > 99 => "w-threedig",
            > 9 => "w-twodig",
            _ => "w-onedig"
        };
    }

    private static string SpecPath(DropLike item) {
        var fixedName = item.Name
            .Replace("_FRAGMENT", "", StringComparison.Ordinal)
            .Replace("ORNATE_GUSSET", "GUSSET", StringComparison.Ordinal)
            .Replace("VIAL_MARTIAN_DUST", "VIAL_OF_MARTIAN_DUST", StringComparison.Ordinal);
        return ContentPaths.Asset($"images/artifacts/{fixedName}/{fixedName}_{item.Level + SpecPathOffset(item)}.png");
    }

    
    private static (string Prefix, string Highlight, string Suffix) BoundEffectString(string str) {
        if (str.StartsWith("!!", StringComparison.Ordinal)) {
            var open = str.IndexOf('<', StringComparison.Ordinal);
            var close = open >= 0 ? str.IndexOf('>', open) : -1;
            return close > open
                ? (str.Substring(2, open - 2), str.Substring(open + 1, close - open - 1), "")
                : ("?", "?", "?");
        }

        var lb = str.IndexOf('[', StringComparison.Ordinal);
        var rb = lb >= 0 ? str.IndexOf(']', lb) : -1;
        return rb > lb
            ? (str.Substring(0, lb), str.Substring(lb + 1, rb - lb - 1), str.Substring(rb + 1))
            : ("?", "?", "?");
    }

    
    private (long Seen, long Total)? DropCalcs(DropLike item) {
        if (MennoData?.Configs is null) {
            return null;
        }

        foreach (var c in MennoData.Configs) {
            var ac = c.ArtifactConfiguration;
            if (ac?.ArtifactType is null || ac.ArtifactRarity is null) {
                continue;
            }

            if (ac.ArtifactType.Id == item.Id && ac.ArtifactLevel == item.Level && ac.ArtifactRarity.Id == item.Rarity) {
                return (c.TotalDrops, MennoData.TotalDropsCount);
            }
        }

        return null;
    }

    
    private string ExpectedPerShip(DropLike item) {
        var calc = DropCalcs(item);
        if (calc is null || calc.Value.Total == 0) {
            return "";
        }

        var v = (double)calc.Value.Seen / calc.Value.Total * MissionTotalDrops;
        return v.ToString("0.000", CultureInfo.InvariantCulture);
    }

}
