@using EggLedger.Web.Settings
@inject IPlatformCapabilities Platform

@* Window sizing for the desktop shell. Pending width/height/fullscreen apply on restart;
   the Restart Now button shows only when they differ from the loaded values. *@

<div class="px-2 py-2 text-sm text-gray-400 bg-darker rounded-md tabular-nums overflow-auto">
    <span class="mr-0_5rem font-bold text-lg text-gray-400 ledger-underline">Window &amp; Browser</span>
    <span class="text-gray-500 text-xs italic ml-1">(effective on restart)</span><br/>

    <div class="mt-0_5rem">
        <span class="section-heading">App Resolution</span><br/>
        <div class="flex flex-row items-center pl-0_5rem">
            <div class="flex flex-col w-full max-w-10rem text-center mt-0_5rem">
                <input type="number" id="resPrefX" class="number-input text-sm bg-darkest"
                       value="@_width" @onchange="OnWidthChangeAsync"/>
                <span class="text-sm text-gray-400 mt-0_5rem">Width<br/>(<span class="text-gray-300">X</span>)</span>
            </div>
            <span class="text-xl font-bold ml-0_5rem mr-0_5rem mb-2_5rem">x</span>
            <div class="flex flex-col w-full max-w-10rem text-center mt-0_5rem">
                <input type="number" id="resPrefY" class="number-input text-sm bg-darkest"
                       value="@_height" @onchange="OnHeightChangeAsync"/>
                <span class="text-sm text-gray-400 mt-0_5rem">Height<br/>(<span class="text-gray-300">Y</span>)</span>
            </div>
            <button type="button"
                    class="apply-filter-button !bg-blue-700 !text-white hover:!bg-blue-600 !border-blue-500 !ml-1rem mb-2_5rem !mt-0 !mr-0"
                    @onclick="CaptureFromCurrentAsync">
                Capture from Current
            </button>
        </div>
        <div class="mt-0_5rem pl-0_5rem">
            <input id="startInFullscreenCheckbox" type="checkbox" class="ext-opt-check mr-0_5rem"
                   checked="@_fullscreen" @onchange="OnFullscreenChangeAsync"/>
            <label for="startInFullscreenCheckbox" class="ext-opt-label">Launch app in fullscreen</label>
        </div>
        @if (NeedsRestart) {
            <div class="mt-0_5rem pl-0_5rem">
                <button type="button"
                        class="apply-filter-button !bg-orange-700 !text-white hover:!bg-orange-600 !border-orange-500 !mt-0 !mr-0 !ml-0"
                        @onclick="Platform.RestartAppAsync">
                    Restart Now
                </button>
                <span class="ml-0_5rem text-gray-400 text-xs">Resolution change takes effect after restart</span>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] [EditorRequired] public SettingsModel Model { get; set; } = default!;

    [Parameter] [EditorRequired] public EventCallback<(string Key, string Value)> OnSetting { get; set; }

    private int _width;
    private int _height;
    private bool _fullscreen;


    private int _loadedWidth;
    private int _loadedHeight;
    private bool _loadedFullscreen;

    private bool NeedsRestart =>
        _width != _loadedWidth || _height != _loadedHeight || _fullscreen != _loadedFullscreen;

    protected override void OnInitialized() {
        _loadedWidth = Model.WindowWidth > 0 ? Model.WindowWidth : SettingsModel.DefaultWindowWidth;
        _loadedHeight = Model.WindowHeight > 0 ? Model.WindowHeight : SettingsModel.DefaultWindowHeight;
        _loadedFullscreen = Model.StartInFullscreen;
        _width = _loadedWidth;
        _height = _loadedHeight;
        _fullscreen = _loadedFullscreen;
    }

    private async Task OnWidthChangeAsync(ChangeEventArgs e) {
        if (int.TryParse(e.Value?.ToString(), out var v) && v > 0) {
            _width = v;
            Model.WindowWidth = v;
            await OnSetting.InvokeAsync((SettingsModel.KeyWindowWidth, SettingsModel.FormatInt(v)));
        }
    }

    private async Task OnHeightChangeAsync(ChangeEventArgs e) {
        if (int.TryParse(e.Value?.ToString(), out var v) && v > 0) {
            _height = v;
            Model.WindowHeight = v;
            await OnSetting.InvokeAsync((SettingsModel.KeyWindowHeight, SettingsModel.FormatInt(v)));
        }
    }

    private async Task OnFullscreenChangeAsync(ChangeEventArgs e) {
        _fullscreen = e.Value is bool b ? b : bool.TryParse(e.Value?.ToString(), out var p) && p;
        Model.StartInFullscreen = _fullscreen;
        await OnSetting.InvokeAsync((SettingsModel.KeyStartInFullscreen, SettingsModel.FormatBool(_fullscreen)));
    }

    private async Task CaptureFromCurrentAsync() {
        var (w, h) = await Platform.GetWindowSizeAsync();
        if (w > 0 && h > 0) {
            _width = w;
            _height = h;
            Model.WindowWidth = w;
            Model.WindowHeight = h;
            await OnSetting.InvokeAsync((SettingsModel.KeyWindowWidth, SettingsModel.FormatInt(w)));
            await OnSetting.InvokeAsync((SettingsModel.KeyWindowHeight, SettingsModel.FormatInt(h)));
        }
    }

}
