@using EggLedger.Domain.MissionQuery
@using EggLedger.Web.Data
@implements IDisposable
@inject ActiveAccount Active
@inject AppStateService AppStateSvc
@inject AccountLoader Loader

<div class="relative">
    <button type="button"
            class="relative -bottom-px flex items-center gap-1.5 px-4 pt-2 pb-1.5 text-sm font-medium text-gray-400 border border-darker_tab rounded-t-md bg-darker_tab hover:bg-dark_tab_hover transition-colors whitespace-nowrap"
            @onclick="Toggle">
        @if (_active is not null) {
            <span class="font-medium" style="color: #@_active.AccountColor">@_active.Nickname</span>
            <span class="text-gray-500 text-xs">@_active.EBString</span>
        } else {
            <span class="text-gray-500 italic text-xs">No account - click to add</span>
        }
        <span class="text-gray-600 ml-1 text-xs">&#9660;</span>
    </button>

    @if (_open) {
        <ul class="absolute right-0 top-full z-50 mt-1 min-w-80 rounded-md border border-gray-600 bg-darkest shadow-xl text-xs">
            @foreach (var acct in Accounts) {
                <li class="flex items-start gap-2 px-3 py-2.5 cursor-pointer hover:bg-darker transition-colors border-b border-gray-800 last:border-b-0"
                    @onclick="() => Select(acct.Id)">
                    <span class="text-gray-500 w-3 flex-shrink-0 mt-0.5">
                        @if (acct.Id == Active.ActiveAccountId) {
                            <text>&#10003;</text>
                        }
                    </span>
                    <span class="flex-1 min-w-0 flex flex-col gap-0.5">
                        <span class="text-gray-400">
                            <MaskedEid Value="@acct.Id"/>
                        </span>
                        <span class="flex items-center gap-1.5">
                            <span class="font-medium" style="color: #@acct.AccountColor">@acct.Nickname</span>
                            <span class="text-gray-500">@acct.EBString</span>
                        </span>
                    </span>
                </li>
            }
            <li class="px-3 py-2 text-center text-privacy_blue hover:bg-darker transition-colors cursor-pointer"
                @onclick="OpenAddDialog">
                + Add Account
            </li>
        </ul>
    }
</div>

<AddAccountDialog @ref="_addDialog" Added="OnAccountAdded"/>

@code {
    private bool _open;
    private KnownAccount? _active;
    private AddAccountDialog? _addDialog;

    private IReadOnlyList<KnownAccount> Accounts =>
        AppStateSvc.KnownAccounts;

    protected override void OnInitialized() {
        Active.Changed += OnStateChanged;
        AppStateSvc.Changed += OnStateChanged;
        RefreshActive();
    }

    private void OnStateChanged() {
        RefreshActive();
        InvokeAsync(StateHasChanged);
    }

    private void RefreshActive() {
        _active = AppStateSvc.KnownAccounts.FirstOrDefault(a => a.Id == Active.ActiveAccountId);
    }

    private void Toggle() {
        _open = !_open;
    }

    private void Select(string id) {
        Active.SetActive(id);
        _open = false;
    }

    private void OpenAddDialog() {
        _open = false;
        _addDialog?.Open();
    }

    private async Task OnAccountAdded(AccountInfo account) {
        await Loader.RefreshAsync();
        Active.SetActive(account.Id);
    }

    public void Dispose() {
        Active.Changed -= OnStateChanged;
        AppStateSvc.Changed -= OnStateChanged;
    }

}
