@implements IDisposable
@using EggLedger.Domain.MissionQuery
@using EggLedger.Web.Data
@using EggLedger.Web.Services
@implements IAsyncDisposable
@inject ActiveAccount Active
@inject AppStateService AppStateSvc
@inject AccountLoader Loader
@inject FetchOrchestrator Fetch
@inject MissionQueryHandlers Queries
@inject IndexedDbSettings SettingsStore
@inject IJSRuntime Js

<div class="relative" @ref="_rootRef">
    <div class="flex items-center">
        @if (IsLoggedIn) {
            <form method="post" action="/api/v1/auth/logout" style="margin:0;">
                <button type="submit"
                        class="relative -bottom-px mr-1.5 px-3 pt-2 pb-1.5 text-xs font-medium text-gray-400 border border-darker_tab rounded-t-md bg-darker_tab hover:bg-dark_tab_hover transition-colors whitespace-nowrap">
                    Log out
                </button>
            </form>
        }
        <button type="button"
                class="relative -bottom-px flex items-center gap-1.5 px-4 pt-2 pb-1.5 text-sm font-medium text-gray-400 border border-darker_tab rounded-t-md bg-darker_tab hover:bg-dark_tab_hover transition-colors whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed"
                disabled="@(!IsLoggedIn)" @onclick="Toggle">
            @if (_active is not null) {
                <span class="font-medium" style="color: #@_active.AccountColor">@_active.Nickname</span>
                <span class="text-gray-500 text-xs">@_active.EBString</span>
            } else if (!IsLoggedIn) {
                <span class="text-gray-500 italic text-xs">Login to add an account</span>
            } else {
                <span class="text-gray-500 italic text-xs">No account - click to add</span>
            }
            <span class="text-gray-600 ml-1 text-xs">&#9660;</span>
        </button>

        @if (Fetch.IsIdle) {
            <button type="button"
                    class="relative -bottom-px ml-1.5 px-3 pt-2 pb-1.5 text-xs font-medium text-gray-400 border border-darker_tab rounded-t-md bg-darker_tab hover:bg-dark_tab_hover transition-colors disabled:opacity-50 disabled:cursor-default whitespace-nowrap"
                    disabled="@(Active.ActiveAccountId is null)" @onclick="StartFetch">
                Fetch
            </button>
        } else {
            <button type="button"
                    class="relative -bottom-px ml-1.5 px-3 pt-2 pb-1.5 text-xs font-medium text-gray-400 border border-darker_tab rounded-t-md bg-darker_tab hover:bg-dark_tab_hover transition-colors whitespace-nowrap"
                    @onclick="StopFetch">
                Stop
            </button>
        }

        @if (!Fetch.IsIdle) {
            <div class="ml-1.5 flex items-center gap-1 text-xs text-yellow-400 tabular-nums whitespace-nowrap">
                <div class="w-12 h-1.5 rounded-sm overflow-hidden bg-dark">
                    <div class="h-full bg-green-500 transition-all duration-300 rounded-sm" style="width: @(Fetch.Percent)%"></div>
                </div>
                <span>@(Fetch.Percent)%</span>
            </div>
        }
    </div>

    @if (_open) {
        <ul class="absolute right-0 top-full z-50 mt-1 min-w-80 rounded-md border border-gray-600 bg-darkest shadow-xl text-xs">
            @foreach (var acct in Accounts) {
                <li class="flex items-start gap-2 px-3 py-2.5 cursor-pointer hover:bg-darker transition-colors border-b border-gray-800 last:border-b-0"
                    @onclick="() => Select(acct.Id)">
                    <span class="text-gray-500 w-3 flex-shrink-0 mt-0.5">
                        @if (acct.Id == Active.ActiveAccountId) {
                            <text>&#10003;</text>
                        }
                    </span>
                    <span class="flex-1 min-w-0 flex flex-col gap-0.5">
                        <span class="text-gray-400">
                            <MaskedEid Value="@acct.Id"/>
                        </span>
                        <span class="flex items-center gap-1.5">
                            <span class="font-medium" style="color: #@acct.AccountColor">@acct.Nickname</span>
                            <span class="text-gray-500">@acct.EBString</span>
                        </span>
                        @{ var info = InfoFor(acct.Id); }
                        @if (info is { SeString: not "" }) {
                            <span class="flex items-center gap-1.5 text-gray-500">
                                <span style="color:#a855f7">@info.SeString SE</span>
                                <span style="color:#eab308">@info.PeCount PE</span>
                                @if (info.TeCount > 0) {
                                    <span style="color:#c831ff">@info.TeCount TE</span>
                                }
                            </span>
                        }
                        @{ var stats = StatsFor(acct.Id); }
                        @if (stats is not null) {
                            <span class="flex items-center gap-1.5 text-gray-600">
                                <span>@stats.MissionCount missions</span>
                                @{ var since = LedgerFormatting.FormatTimeSince(stats.LastMissionReturnDT, NowUnix); }
                                @if (since != "") {
                                    <span>&middot; latest @since</span>
                                }
                            </span>
                        }
                    </span>
                </li>
            }
            <li class="px-3 py-2 text-center text-privacy_blue hover:bg-darker transition-colors cursor-pointer"
                @onclick="OpenAddDialog">
                + Add Account
            </li>
        </ul>
    }
</div>

<AddAccountDialog @ref="_addDialog" Added="OnAccountAdded"/>

@code {

    [CascadingParameter(Name = "IsLoggedIn")]
    private bool IsLoggedIn { get; set; } = true;

    private bool _open;
    private KnownAccount? _active;
    private AddAccountDialog? _addDialog;
    private ElementReference _rootRef;
    private DotNetObjectReference<GlobalAccountHeader>? _selfRef;
    private IReadOnlyList<DatabaseAccount> _existing = [];
    private bool _lastWarnedFetchActive;
    private static int _nextId;
    private readonly string _registrationId = $"account-header-{Interlocked.Increment(ref _nextId)}";

    private static double NowUnix => DateTimeOffset.UtcNow.ToUnixTimeSeconds();

    private IReadOnlyList<KnownAccount> Accounts =>
        AppStateSvc.KnownAccounts;

    private AccountInfo? InfoFor(string id) {
        return Loader.Accounts.FirstOrDefault(a => a.Id == id);
    }

    private DatabaseAccount? StatsFor(string id) {
        return _existing.FirstOrDefault(a => a.Id == id);
    }

    protected override async Task OnInitializedAsync() {
        Active.Changed += OnStateChanged;
        AppStateSvc.Changed += OnStateChanged;
        Fetch.Changed += OnStateChanged;
        RefreshActive();
        await RefreshExistingAsync();
        await ResumeIncompleteFetchAsync();
    }

    
    
    
    private async Task ResumeIncompleteFetchAsync() {
        if (!Fetch.IsIdle) {
            return;
        }

        var incomplete = await FetchOrchestrator.GetIncompleteAccountsAsync(SettingsStore);
        var knownIds = AppStateSvc.KnownAccounts.Select(a => a.Id).ToHashSet();
        if (incomplete.FirstOrDefault(knownIds.Contains) is { } resumeId) {
            _ = StartFetchFor(resumeId);
        }
    }

    private void OnStateChanged() {
        RefreshActive();
        _ = SyncUnloadWarningAsync();
        InvokeAsync(StateHasChanged);
    }

    private async Task SyncUnloadWarningAsync() {
        var active = !Fetch.IsIdle;
        if (active == _lastWarnedFetchActive) {
            return;
        }

        _lastWarnedFetchActive = active;
        try {
            await Js.InvokeVoidAsync("setFetchInProgressWarning", active);
        }
        catch (JSDisconnectedException) {
            
        }
    }

    private void RefreshActive() {
        _active = AppStateSvc.KnownAccounts.FirstOrDefault(a => a.Id == Active.ActiveAccountId);
    }

    private async Task RefreshExistingAsync() {
        _existing = await Queries.GetExistingDataAsync();
    }

    private async Task StartFetch() {
        if (Active.ActiveAccountId is not { } id) {
            return;
        }

        await StartFetchFor(id);
    }

    private async Task StartFetchFor(string id) {
        await Fetch.StartFetchAsync(id);
        await RefreshExistingAsync();
        await Loader.RefreshAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void StopFetch() {
        Fetch.StopFetch();
    }

    private async Task Toggle() {
        _open = !_open;
        if (_open) {
            await RegisterOutsideClickAsync();
        } else {
            await UnregisterOutsideClickAsync();
        }
    }

    private async Task Select(string id) {
        Active.SetActive(id);
        _open = false;
        await UnregisterOutsideClickAsync();
    }

    private async Task OpenAddDialog() {
        _open = false;
        await UnregisterOutsideClickAsync();
        _addDialog?.Open();
    }

    private async Task OnAccountAdded(AccountInfo account) {
        await Loader.RefreshAsync();
        Active.SetActive(account.Id);
        await StartFetch();
    }

    private async Task RegisterOutsideClickAsync() {
        _selfRef ??= DotNetObjectReference.Create(this);
        await Js.InvokeVoidAsync("outsideClickRegister", _registrationId, _rootRef, _selfRef);
    }

    private async Task UnregisterOutsideClickAsync() {
        await Js.InvokeVoidAsync("outsideClickUnregister", _registrationId);
    }

    [JSInvokable]
    public async Task OnOutsideClick() {
        _open = false;
        await UnregisterOutsideClickAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose() {
        Active.Changed -= OnStateChanged;
        AppStateSvc.Changed -= OnStateChanged;
        Fetch.Changed -= OnStateChanged;
    }

    public async ValueTask DisposeAsync() {
        if (_open) {
            await UnregisterOutsideClickAsync();
        }

        _selfRef?.Dispose();
    }

}
