@using EggLedger.Domain.MissionPacking
@using EggLedger.Domain.MissionQuery
@using EggLedger.Web.Missions
@inject MissionQueryHandlers Queries

@* Single-mode mission overlay. Blazor-controlled overlay (full-screen fixed backdrop +
   centered panel). NOT a native <dialog>.showModal(): top-layer promotion desyncs the
   Blazor Server render tree (insertBefore/parentNode-null crashes). Backdrop click closes.
   Multi mode deferred. *@

@if (_open)
{
<div class="fixed inset-0 z-40 flex items-center justify-center bg-black/60" @onclick="Close">
<div class="mission-overlay w-60vw max-h-95vh bg-dark rounded-lg relative flex flex-col" @onclick:stopPropagation="true">
    <button class="absolute top-2 right-2 z-10 rounded-md text-gray-400 hover:text-gray-200 focus:outline-none" type="button" @onclick="Close" aria-label="Close">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
    </button>

    <button class="disabled:cursor-not-allowed absolute left-2 top-1/2 -translate-y-1/2 z-10 rounded-md text-gray-400 focus:outline-none disabled:text-gray-600 hover:text-gray-200" type="button" title="Previous mission"
            disabled="@(_data?.PrevMission is null)"
            @onclick="@(() => NavigateAsync(_data?.PrevMission))">
        <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
    </button>
    <button class="disabled:cursor-not-allowed absolute right-2 top-1/2 -translate-y-1/2 z-10 rounded-md text-gray-400 focus:outline-none disabled:text-gray-600 hover:text-gray-200" type="button" title="Next mission"
            disabled="@(_data?.NextMission is null)"
            @onclick="@(() => NavigateAsync(_data?.NextMission))">
        <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
    </button>

    <div class="overflow-auto flex-1 min-h-0 pt-8 px-10 pb-2">
        <div class="bg-darkerer rounded-lg py-2">
            @if (_data is not null)
            {
                <ShipDisplay Data="_data" />
            }
        </div>
    </div>
</div>
</div>
}

@code {
    [Parameter]
    public string? AccountId { get; set; }

    /// <summary>Filtered missions in display order; drives prev/next navigation.</summary>
    [Parameter]
    public IReadOnlyList<DatabaseMission> FilteredMissions { get; set; } = Array.Empty<DatabaseMission>();

    [Parameter]
    public MissionSortMethod SortMethod { get; set; } = MissionSortMethod.Default;

    private bool _open;
    private ViewMissionData? _data;

    public async Task OpenAsync(string missionId)
    {
        _open = true;
        await LoadAsync(missionId);
    }

    private async Task LoadAsync(string missionId)
    {
        var mission = FindMission(missionId);
        if (mission is null)
        {
            _data = null;
            StateHasChanged();
            return;
        }

        var drops = AccountId is null
            ? null
            : await Queries.GetShipDropsAsync(AccountId, missionId);

        var data = MissionDetailBuilder.BuildBase(
            mission,
            drops ?? new List<MissionDrop>(),
            FilteredMissions,
            extendedInfo: true);
        MissionDetailBuilder.ApplySortMethod(data, SortMethod);
        _data = data;
        StateHasChanged();
    }

    private DatabaseMission? FindMission(string missionId)
    {
        foreach (var m in FilteredMissions)
        {
            if (m.MissiondId == missionId)
            {
                return m;
            }
        }
        return null;
    }

    private async Task NavigateAsync(string? missionId)
    {
        if (missionId is not null)
        {
            await LoadAsync(missionId);
        }
    }

    private void Close()
    {
        _open = false;
        _data = null;
    }
}
