@using EggLedger.Web.Missions
@* Searchable modal picker (port of the Vue SearchOverSelector). A readonly trigger field
   opens a Blazor-controlled overlay (full-screen fixed backdrop + centered panel). NOT a
   native <dialog>.showModal(): top-layer promotion desyncs the Blazor Server render tree
   (insertBefore/parentNode-null crashes). Backdrop click closes. Drops show a rarity ring. *@

<input type="text" readonly placeholder="@Placeholder"
       class="filter-select w-auto border-gray-600 @(Selected?.StyleClass ?? "text-gray-400") cursor-pointer"
       value="@(Selected?.Text ?? "")"
       @onclick="Open"/>

@if (_open) {
    <dialog open class="popup-selector-main overlay-@OverlayKind" @onclick="Close">
        <div class="popup-selector-inner" @onclick:stopPropagation="true"
             @onkeydown="OnKeyDown" @onkeydown:preventDefault="_preventKey">
            <button type="button" class="close-button" @onclick="Close" aria-label="Close">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
            <input @ref="_searchInput" type="text" class="input-search" placeholder="Search..."
                   value="@_query" @oninput="OnQueryInput"/>
            <div class="popup-opt-container">
                @{
                    var filtered = Filtered();
                    var segments = BuildSegments(filtered);
                }
                @if (filtered.Count == 0) {
                    <span class="text-gray-400">No results found.</span>
                } else {
                    @foreach (var segment in segments) {
                        @if (segment.GroupLabel is null) {
                            var opt = segment.Items[0].Option;
                            var idx = segment.Items[0].Index;
                            <div class="popup-opt @(idx == _activeIndex ? "selected-popup-opt" : "")"
                                 @onclick="() => Choose(opt)">
                                @if (!string.IsNullOrEmpty(opt.ImagePath)) {
                                    <img class="max-w-7 mr-1rem @RingClass(opt)" loading="lazy" decoding="async"
                                         alt="@opt.Text" src="@ImageSrc(opt)"/>
                                }
                                <span class="@(opt.StyleClass ?? "text-gray-400")">@opt.Text</span>
                            </div>
                        } else {
                            <div class="popup-opt-group">
                                <span class="popup-opt-group-label">@segment.GroupLabel</span>
                                <div class="flex flex-wrap gap-1">
                                    @foreach (var (opt, idx) in segment.Items) {
                                        <button type="button" class="popup-opt-chip relative @(idx == _activeIndex ? "selected-popup-opt" : "")"
                                                @onclick="() => Choose(opt)"
                                                @onmouseenter="@(() => _hoveredChip = opt)" @onmouseleave="@(() => _hoveredChip = null)">
                                            @if (!string.IsNullOrEmpty(opt.ImagePath)) {
                                                <img class="w-7 h-7 @RingClass(opt)" loading="lazy" decoding="async"
                                                     alt="@opt.Text" src="@ImageSrc(opt)"/>
                                            }
                                            @if (!string.IsNullOrEmpty(opt.Badge)) {
                                                <span class="popup-opt-chip-badge @(opt.StyleClass ?? "text-gray-400")">@opt.Badge</span>
                                            }
                                            @if (ReferenceEquals(_hoveredChip, opt)) {
                                                <div class="tooltip-floating tooltip-anchored text-sm">
                                                    @opt.Text
                                                    @if (opt.Rarity is { } r) {
                                                        <br/>
                                                        <span class="@(opt.StyleClass ?? "text-gray-400")">@FilterOptions.RarityWord(r)</span>
                                                    }
                                                </div>
                                            }
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    }
                }
            </div>
            @if (Footer is not null) {
                <div class="flex items-center gap-1.5 px-1 pt-1 pb-0.5 text-xs text-gray-400 border-t border-gray-600 mr-1rem">@Footer</div>
            }
        </div>
    </dialog>
}

@code {
    [Parameter] public IReadOnlyList<FilterOption> Options { get; set; } = [];
    [Parameter] public string? SelectedValue { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Click to select";
    [Parameter] public string ImageBasePath { get; set; } = "images/";
    [Parameter] public bool RarityRing { get; set; }
    [Parameter] public string OverlayKind { get; set; } = "drop";
    [Parameter] public EventCallback<FilterOption> OnSelect { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }
    private bool _open;
    private bool _focusPending;
    private bool _preventKey;
    private ElementReference _searchInput;
    private string _query = "";
    private int _activeIndex = -1;
    private FilterOption? _hoveredChip;

    private FilterOption? Selected =>
        SelectedValue is null ? null : Options.FirstOrDefault(o => o.Value == SelectedValue);

    private List<FilterOption> Filtered() {
        return string.IsNullOrWhiteSpace(_query)
            ? [.. Options]
            : [.. Options.Where(o => o.Text.Contains(_query, StringComparison.OrdinalIgnoreCase))];
    }

    private sealed record PickerSegment(string? GroupLabel, List<(FilterOption Option, int Index)> Items);

    private static List<PickerSegment> BuildSegments(List<FilterOption> filtered) {
        var segments = new List<PickerSegment>();
        string? currentKey = null;
        for (var i = 0; i < filtered.Count; i++) {
            var opt = filtered[i];
            if (opt.GroupKey is not null && opt.GroupKey == currentKey) {
                segments[^1].Items.Add((opt, i));
            } else {
                segments.Add(new PickerSegment(opt.GroupKey is null ? null : opt.GroupLabel, [(opt, i)]));
                currentKey = opt.GroupKey;
            }
        }

        return segments;
    }

    private string ImageSrc(FilterOption o) {
        return ContentPaths.Asset(ImageBasePath + o.ImagePath);
    }

    private string RingClass(FilterOption o) {
        if (RarityRing && o.Rarity is { } r) {
            return $"rounded-full bg-r-{r}";
        }
        return o.ImagePath == "icon_help.webp" ? "rounded-full bg-gray-500" : "";
    }

    private void Open() {
        _query = "";
        _activeIndex = -1;
        _open = true;
        _focusPending = true;
    }

    private void Close() {
        _open = false;
    }

    
    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (_focusPending) {
            _focusPending = false;
            try {
                await _searchInput.FocusAsync();
            }
            catch {
                /* element gone (closed before focus) - ignore */
            }
        }
    }

    private void OnQueryInput(ChangeEventArgs e) {
        _query = e.Value?.ToString() ?? "";
        _activeIndex = -1;
    }

    private void OnKeyDown(KeyboardEventArgs e) {
        var filtered = Filtered();
        _preventKey = e.Key is "ArrowDown" or "ArrowUp" or "Enter";
        switch (e.Key) {
            case "ArrowDown":
                _activeIndex = filtered.Count == 0 ? -1 : Math.Min(_activeIndex + 1, filtered.Count - 1);
                break;
            case "ArrowUp":
                _activeIndex = Math.Max(_activeIndex - 1, 0);
                break;
            case "Enter" when _activeIndex >= 0 && _activeIndex < filtered.Count:
                _ = Choose(filtered[_activeIndex]);
                break;
            case "Escape":
                Close();
                break;
        }
    }

    private async Task Choose(FilterOption opt) {
        _open = false;
        await OnSelect.InvokeAsync(opt);
    }

}
