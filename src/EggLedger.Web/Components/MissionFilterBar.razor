@using System.Globalization
@using EggLedger.Web.Missions
@using EggLedger.Web.Missions.Model

@* AND rows within a group, OR between groups. Emits a typed MissionFilter. *@

<div class="max-h-96 overflow-y-auto">
    @for (var gi = 0; gi < _groups.Count; gi++)
    {
        var groupIndex = gi;
        var group = _groups[groupIndex];

        @if (groupIndex != 0)
        {
            <div class="text-blue-400 font-bold mt-1rem mb-0_5rem">-- OR --</div>
        }

        @for (var ri = 0; ri < group.Count; ri++)
        {
            var rowIndex = ri;
            var row = group[rowIndex];
            var def = FilterFields.GetReportField(row.TopLevel);
            <div class="relative flex-grow max-h-6/10">
                @if (rowIndex != 0)
                {
                    <div class="text-gray-400 mt-0_5rem">-- AND --</div>
                }
                <div class="filter-container focus-within:z-10">
                    <select class="filter-select border-gray-300 text-gray-400" value="@row.TopLevel"
                            @onchange="@(e => OnFieldChanged(groupIndex, rowIndex, e.Value?.ToString()))">
                        @foreach (var f in _fields)
                        {
                            <option value="@f.Key" class="filter-select-option">@f.Label</option>
                        }
                    </select>

                    @if (def is not null)
                    {
                        @if (def.ValueKind != FilterValueKind.Bool)
                        {
                            <select class="filter-select border-gray-300 text-gray-400" value="@row.Op"
                                    @onchange="@(e => OnOpChanged(groupIndex, rowIndex, e.Value?.ToString()))">
                                @foreach (var op in FilterFields.MissionBarOpsFor(def))
                                {
                                    <option value="@op.Value" class="filter-select-option">@op.Label</option>
                                }
                            </select>
                        }
                        else
                        {
                            <span class="text-gray-400 mt-0_5rem mr-1rem">is</span>
                        }

                        @if (def.ValueKind is FilterValueKind.Select)
                        {
                            <select class="filter-select border-gray-300 text-gray-400" value="@row.Val"
                                    @onchange="@(e => OnValChanged(groupIndex, rowIndex, e.Value?.ToString()))">
                                @foreach (var opt in OptionsFor(def))
                                {
                                    <option value="@opt.Value" class="filter-select-option @opt.StyleClass">@opt.Text</option>
                                }
                            </select>
                        }
                        else if (def.ValueKind is FilterValueKind.Bool)
                        {
                            <select class="filter-select border-gray-300 text-gray-400" value="@row.Val"
                                    @onchange="@(e => OnValChanged(groupIndex, rowIndex, e.Value?.ToString()))">
                                @foreach (var opt in FilterOptions.GetBoolFilterOptions())
                                {
                                    <option value="@opt.Value" class="filter-select-option">@opt.Text</option>
                                }
                            </select>
                        }
                        else if (def.ValueKind is FilterValueKind.Date)
                        {
                            <input type="date" class="filter-select border-gray-300 text-gray-400" value="@row.Val"
                                   @onchange="@(e => OnValChanged(groupIndex, rowIndex, e.Value?.ToString()))" />
                        }
                        else if (def.ValueKind is FilterValueKind.Number)
                        {
                            <input type="number" class="filter-select border-gray-300 text-gray-400" value="@row.Val"
                                   @onchange="@(e => OnValChanged(groupIndex, rowIndex, e.Value?.ToString()))" />
                        }
                        else if (def.ValueKind is FilterValueKind.Modal)
                        {
                            var isDrop = def.Key == "drops";
                            <SearchablePicker Options="OptionsFor(def)"
                                              SelectedValue="@row.Val"
                                              Placeholder="@($"Select {def.Label}...")"
                                              ImageBasePath="@(isDrop ? "images/" : "images/targets/")"
                                              RarityRing="isDrop"
                                              OverlayKind="@(isDrop ? "drop" : "target")"
                                              OnSelect="opt => OnValChanged(groupIndex, rowIndex, opt.Value)"
                                              Footer="@(isDrop ? DropAdvancedFooter : null)" />
                        }
                    }

                    @if (group.Count > 1)
                    {
                        <button type="button" title="Remove filter condition"
                                class="mr-1rem flex items-center justify-center text-red-700 text-lg max-w-6 max-h-6 min-w-6 min-h-6 border border-red-700 rounded-md bg-transparent mt-0_5rem filter-button"
                                @onclick="@(() => RemoveRow(groupIndex, rowIndex))" aria-label="Remove">&times;</button>
                    }
                </div>
            </div>
        }
    }

    <button type="button" class="text-blue-400 text-sm toggle-link mt-1rem" @onclick="AddOrGroup">+ OR group</button>
</div>

<hr class="mt-1rem w-full" />

<button type="button" class="apply-filter-button" disabled="@Applying" @onclick="ApplyAsync">Apply Filter</button>
@if (Applying)
{
    <span class="text-green-700 mt-0_5rem"><i>Applying filter, please wait...</i></span>
}
else if (LastResultText is { Length: > 0 })
{
    <span class="text-gray-500 mt-0_5rem"><i>@LastResultText</i></span>
}

@code {
    [Parameter] public FilterFieldCtx FieldCtx { get; set; } = new();
    [Parameter] public bool Applying { get; set; }
    [Parameter] public string LastResultText { get; set; } = "";
    [Parameter] public EventCallback<MissionFilter> OnApply { get; set; }

    private readonly List<List<FilterCondition>> _groups = [];
    private List<FilterFieldDef> _fields = [];
    private readonly Dictionary<string, List<FilterOption>> _optionCache = [];
    private bool _advancedDrops = true;

    protected override void OnInitialized()
    {
        _fields = FilterFields.ReportMissionFields();
        if (_groups.Count == 0)
            _groups.Add([NewRow(_fields[0])]);
    }

    private RenderFragment DropAdvancedFooter => @<label class="flex items-center gap-1.5 text-xs text-gray-400 cursor-pointer select-none">
        <input type="checkbox" class="ext-opt-check" checked="@_advancedDrops" @onchange="OnAdvancedDropsToggled" />
        Advanced (family groupings)
    </label>;

    private void OnAdvancedDropsToggled(ChangeEventArgs e)
    {
        _advancedDrops = e.Value is true;
        _optionCache.Remove("drops");
    }

    private FilterCondition NewRow(FilterFieldDef def)
    {
        // Bool fields carry the operator ("true"/"false") in Val; Op is unused.
        if (def.ValueKind == FilterValueKind.Bool)
            return new FilterCondition(def.Key, "=", "true");
        return new FilterCondition(def.Key, FilterFields.DefaultOpForField(def), DefaultValueFor(def));
    }

    private string DefaultValueFor(FilterFieldDef def)
    {
        if (def.ValueKind != FilterValueKind.Select)
            return "";
        var opts = OptionsFor(def);
        return opts.Count > 0 ? opts[0].Value : "";
    }

    private List<FilterOption> OptionsFor(FilterFieldDef def)
    {
        if (def.OptionsSource is null)
            return [];
        if (_optionCache.TryGetValue(def.Key, out var cached))
            return cached;

        var opts = def.Key == "drops"
            ? FilterOptions.GetDropFilterOptions(FieldCtx.ArtifactConfigs, FieldCtx.MaxQuality, _advancedDrops)
            : def.OptionsSource(FieldCtx);
        _optionCache[def.Key] = opts;
        return opts;
    }

    private void OnFieldChanged(int groupIndex, int rowIndex, string? key)
    {
        var def = FilterFields.GetReportField(key ?? "") ?? _fields[0];
        _groups[groupIndex][rowIndex] = NewRow(def);
        EnsureTrailingRow(groupIndex);
    }

    private void OnOpChanged(int groupIndex, int rowIndex, string? op) =>
        _groups[groupIndex][rowIndex].Op = op ?? "";

    private void OnValChanged(int groupIndex, int rowIndex, string? val)
    {
        _groups[groupIndex][rowIndex].Val = val ?? "";
        EnsureTrailingRow(groupIndex);
    }

    // A group always shows one blank trailing row; filling it appends another.
    private void EnsureTrailingRow(int groupIndex)
    {
        var group = _groups[groupIndex];
        var lastDef = FilterFields.GetReportField(group[^1].TopLevel);
        bool lastFilled = lastDef is not null
            && (lastDef.ValueKind == FilterValueKind.Bool || group[^1].Val.Length > 0);
        if (lastFilled)
            group.Add(NewRow(_fields[0]));
    }

    private void RemoveRow(int groupIndex, int rowIndex)
    {
        var group = _groups[groupIndex];
        group.RemoveAt(rowIndex);
        if (group.Count == 0)
        {
            if (_groups.Count > 1)
                _groups.RemoveAt(groupIndex);
            else
                group.Add(NewRow(_fields[0]));
        }
    }

    private void AddOrGroup() => _groups.Add([NewRow(_fields[0])]);

    private async Task ApplyAsync()
    {
        var filterGroups = new List<FilterGroup>();
        foreach (var group in _groups)
        {
            var conditions = new List<Condition>();
            foreach (var row in group)
            {
                var def = FilterFields.GetReportField(row.TopLevel);
                if (def is null)
                    continue;
                if (def.ValueKind != FilterValueKind.Bool && row.Val.Length == 0)
                    continue;
                if (FilterCodec.FromLegacyCondition(row) is { } typed)
                    conditions.Add(typed);
            }
            if (conditions.Count > 0)
                filterGroups.Add(new FilterGroup(conditions));
        }

        await OnApply.InvokeAsync(new MissionFilter(filterGroups));
    }
}
