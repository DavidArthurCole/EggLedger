@using EggLedger.Web.Missions
@* Faithful port of the Vue FullFilter. Each AND row builds progressively: field
   first, operator after a field is chosen, value after the operator. A complete
   row gets a yellow OR button that adds an indented "⮡ OR" sibling under it
   (legacy per-condition OR rescue). Emits the legacy (and, orFilters) shape so the
   matcher reproduces Vue semantics exactly (see docs/filter-legacy-semantics.md). *@

<div class="max-h-60 overflow-y-auto">
    @for (var i = 0; i < _rows.Count; i++) {
        var index = i;
        var row = _rows[index];

        @if (index != 0) {
            <div class="text-gray-400 mt-0_5rem">-- AND --</div>
        }

        <div class="filter-container">
            @RenderConditionControls(row.Cond, () => OnRowChanged(index))

            @if (RowComplete(row.Cond)) {
                <button type="button" title="Add alternate filter condition"
                        class="mr-1rem flex items-center h-6 w-6 justify-center text-xs font-medium border text-yellow-700 border-yellow-700 bg-darkest rounded-md mt-0_5rem ledger-btn"
                        disabled="@OrAddDisabled(index)"
                        @onclick="() => AddOr(index)">
                    OR
                </button>
            }

            @if (FieldOf(row.Cond) is not null) {
                <button type="button" title="Remove filter condition" aria-label="Remove"
                        class="mr-1rem flex items-center justify-center text-red-700 text-lg max-w-6 max-h-6 min-w-6 min-h-6 border border-red-700 rounded-md bg-transparent mt-0_5rem ledger-btn"
                        @onclick="() => RemoveRow(index)">
                    &times;
                </button>
            }

            @RenderWarning(row.Cond)
        </div>

        @for (var oi = 0; oi < row.Or.Count; oi++) {
            var orIndex = oi;
            var orRow = row.Or[orIndex];
            <div class="ml-2rem filter-container">
                <div class="text-gray-400 mt-0_5rem mr-1rem"><span class="text-gray text-lg">⮡ </span> OR</div>

                @RenderConditionControls(orRow, () => OnOrRowChanged(index))

                <button type="button" title="Remove alternate condition" aria-label="Remove"
                        class="mr-1rem flex items-center justify-center text-red-700 text-lg max-w-6 max-h-6 min-w-6 min-h-6 border border-red-700 rounded-md bg-transparent mt-0_5rem ledger-btn"
                        @onclick="() => RemoveOr(index, orIndex)">
                    &times;
                </button>

                @RenderWarning(orRow)
            </div>
        }
    }
</div>

@if (ShowApply) {
    <hr class="mt-1rem w-full"/>

    <button type="button" class="ledger-btn apply-filter-button" disabled="@Applying" @onclick="ApplyAsync">Apply Filter</button>
    @if (Applying) {
        <span class="text-green-700 mt-0_5rem">
            <i>Applying filter, please wait...</i>
        </span>
    } else if (LastResultText is { Length: > 0 }) {
        <span class="text-green-700 mt-0_5rem">
            <i>@RenderResultText(LastResultText)</i>
        </span>
    }
}

@code {
    [Parameter] public FilterFieldCtx FieldCtx { get; set; } = new();
    [Parameter] public bool Applying { get; set; }
    [Parameter] public string LastResultText { get; set; } = "";
    [Parameter] public EventCallback<LegacyFilter> OnApply { get; set; }
    [Parameter] public bool IsLifetime { get; set; }

    /// <summary>Show the Apply button + status. Off when embedded in a dialog that saves on its own submit.</summary>
    [Parameter]
    public bool ShowApply { get; set; } = true;

    /// <summary>Include artifact-scope fields (name/rarity/tier/spec type/quality). On for Reports, off for Mission Data.</summary>
    [Parameter]
    public bool IncludeArtifactFields { get; set; }

    /// <summary>Seed rows from an existing filter (Reports edit). Mission Data leaves these null (transient).</summary>
    [Parameter]
    public IReadOnlyList<FilterCondition>? InitialAnd { get; set; }

    [Parameter] public IReadOnlyList<IReadOnlyList<FilterCondition>?>? InitialOr { get; set; }

    /// <summary>The legacy AND list + parallel per-index OR-sibling lists the matcher consumes.</summary>
    public sealed record LegacyFilter(
        IReadOnlyList<FilterCondition> And,
        IReadOnlyList<IReadOnlyList<FilterCondition>?> Or);

    private sealed class Row {
        public FilterCondition Cond { get; } = new();
        public List<FilterCondition> Or { get; } = [];
    }

    private readonly List<Row> _rows = [];
    private readonly Dictionary<string, List<FilterOption>> _optionCache = [];
    private bool _advancedDrops = true;

    protected override void OnInitialized() {
        TopLevelFields = IncludeArtifactFields
            ? [.. FilterFields.ReportFilterFields]
            : FilterFields.ReportMissionFields();

        if (InitialAnd is { Count: > 0 }) {
            for (var i = 0; i < InitialAnd.Count; i++) {
                var row = new Row();
                Copy(InitialAnd[i], row.Cond);
                var siblings = InitialOr is not null && i < InitialOr.Count ? InitialOr[i] : null;
                if (siblings is not null)
                    foreach (var s in siblings) {
                        var sc = new FilterCondition();
                        Copy(s, sc);
                        row.Or.Add(sc);
                    }

                _rows.Add(row);
            }
        }

        if (_rows.Count == 0 || !string.IsNullOrEmpty(_rows[^1].Cond.TopLevel))
            _rows.Add(new Row());
    }

    private static void Copy(FilterCondition from, FilterCondition to) {
        to.TopLevel = from.TopLevel;
        to.Op = from.Op;
        to.Val = from.Val;
    }

    private List<FilterFieldDef> TopLevelFields { get; set; } = [];

    private FilterFieldDef? FieldOf(FilterCondition c) =>
        string.IsNullOrEmpty(c.TopLevel) ? null : FilterFields.GetReportField(c.TopLevel);

    private bool RowComplete(FilterCondition c) {
        var def = FieldOf(c);
        if (def is null || string.IsNullOrEmpty(c.Op))
            return false;
        if (def.ValueKind == FilterValueKind.Bool)
            return true;
        if (def.ValueKind == FilterValueKind.Date)
            return c.Val.Length > 0;
        return c.Val.Length > 0;
    }

    private bool RowIncomplete(FilterCondition c) {
        var def = FieldOf(c);
        // Nothing picked yet: not flagged.
        if (def is null)
            return false;
        return !RowComplete(c);
    }

    private bool OrAddDisabled(int index) {
        var or = _rows[index].Or;
        if (or.Count == 0)
            return false;
        return !RowComplete(or[^1]);
    }

    // value-control rendering

    private RenderFragment RenderConditionControls(FilterCondition c, Action changed) => __builder => {
        var def = FieldOf(c);

        <select class="filter-select border-gray-300 text-gray-400" value="@c.TopLevel"
                @onchange="@(e => {
                               SetField(c, e.Value?.ToString());
                               changed();
                           })">
            <option value="" class="filter-select-option">Field...</option>
            @foreach (var f in TopLevelFields) {
                <option value="@f.Key" class="filter-select-option">@f.Label</option>
            }
        </select>

        @if (def is not null) {
            var ops = FilterFields.MissionBarOpsFor(def);
            @if (def.ValueKind == FilterValueKind.Bool) {
                <span class="text-gray-400 mt-0_5rem mr-1rem">is</span>
            } else {
                <select class="filter-select border-gray-300 text-gray-400 @(ops.Count <= 1 ? "opacity-60 cursor-not-allowed" : "")"
                        value="@c.Op" disabled="@(ops.Count <= 1)"
                        @onchange="@(e => {
                                       c.Op = e.Value?.ToString() ?? "";
                                       changed();
                                   })">
                    @foreach (var op in ops) {
                        <option value="@op.Value" class="filter-select-option">@op.Label</option>
                    }
                </select>
            }

            @if (!string.IsNullOrEmpty(c.Op) || def.ValueKind == FilterValueKind.Bool) {
                @switch (def.ValueKind) {
                    case FilterValueKind.Select:
                        <select class="filter-select border-gray-300 text-gray-400" value="@c.Val"
                                @onchange="@(e => {
                                               c.Val = e.Value?.ToString() ?? "";
                                               changed();
                                           })">
                            @foreach (var opt in OptionsFor(def)) {
                                <option value="@opt.Value" class="filter-select-option @opt.StyleClass">@opt.Text</option>
                            }
                        </select>
                        break;
                    case FilterValueKind.Bool:
                        <select class="filter-select border-gray-300 text-gray-400" value="@c.Val"
                                @onchange="@(e => {
                                               c.Val = e.Value?.ToString() ?? "";
                                               changed();
                                           })">
                            @foreach (var opt in FilterOptions.GetBoolFilterOptions()) {
                                <option value="@opt.Value" class="filter-select-option">@opt.Text</option>
                            }
                        </select>
                        break;
                    case FilterValueKind.Date:
                        <input type="date" class="filter-select border-gray-300 text-gray-400" value="@c.Val"
                               @onchange="@(e => {
                                              c.Val = e.Value?.ToString() ?? "";
                                              changed();
                                          })"/>
                        break;
                    case FilterValueKind.Number:
                        <input type="number" class="filter-select border-gray-300 text-gray-400" value="@c.Val"
                               @onchange="@(e => {
                                              c.Val = e.Value?.ToString() ?? "";
                                              changed();
                                          })"/>
                        break;
                    case FilterValueKind.Modal:
                        var isDrop = def.Key == "drops";
                        <SearchablePicker Options="OptionsFor(def)"
                                          SelectedValue="@ModalSelectedValue(def, c.Val)"
                                          Placeholder="@($"Select {def.Label}...")"
                                          ImageBasePath="@(isDrop ? "images/" : "images/targets/")"
                                          RarityRing="isDrop"
                                          OverlayKind="@(isDrop ? "drop" : "target")"
                                          OnSelect="opt => { c.Val = opt.Value; changed(); }"
                                          Footer="@(isDrop ? DropAdvancedFooter : null)"/>
                        break;
                }
            }
        }
    };

    private RenderFragment RenderWarning(FilterCondition c) => __builder => {
        var def = FieldOf(c);
        @if (def is not null && RowIncomplete(c)) {
            <span class="filter-incomplete">(!) Incomplete, will not apply</span>
        }
    };

    // Splits "Filtered in Xs (N shown, M filtered out)" into a green outer phrase
    // with a gray parenthetical wrapping a green inner count, matching the Go/Vue layout.
    private static RenderFragment RenderResultText(string text) => __builder => {
        var openParen = text.IndexOf('(');
        var closeParen = openParen < 0 ? -1 : text.LastIndexOf(')');
        if (openParen < 0 || closeParen < openParen) {
            @text
            return;
        }

        var prefix = text[..openParen];
        var inner = text[(openParen + 1)..closeParen];

        @prefix
        <span class="text-gray-500">
            (<span class="text-green-700">@inner</span>)
        </span>
    };

    // The modal value shows the option's label; SearchablePicker matches by Value, so pass the raw stored value.
    private static string? ModalSelectedValue(FilterFieldDef def, string val) =>
        string.IsNullOrEmpty(val) ? null : val;

    private RenderFragment DropAdvancedFooter => @<label class="flex items-center gap-1.5 text-xs text-gray-400 cursor-pointer select-none">
                                                     <input type="checkbox" class="ext-opt-check" checked="@_advancedDrops" @onchange="OnAdvancedDropsToggled"/>
                                                     Advanced (family groupings)
                                                 </label>;

    private void OnAdvancedDropsToggled(ChangeEventArgs e) {
        _advancedDrops = e.Value is true;
        _optionCache.Remove("drops");
    }

    private List<FilterOption> OptionsFor(FilterFieldDef def) {
        if (def.OptionsSource is null)
            return [];
        if (_optionCache.TryGetValue(def.Key, out var cached))
            return cached;

        var opts = def.Key == "drops"
            ? FilterOptions.GetDropFilterOptions(FieldCtx.ArtifactConfigs, FieldCtx.MaxQuality, _advancedDrops)
            : def.OptionsSource(FieldCtx);
        _optionCache[def.Key] = opts;
        return opts;
    }

    // Field change resets op + value to the new field's defaults.
    private void SetField(FilterCondition c, string? key) {
        c.TopLevel = key ?? "";
        var def = FieldOf(c);
        if (def is null) {
            c.Op = "";
            c.Val = "";
            return;
        }

        c.Op = FilterFields.DefaultOpForField(def);
        c.Val = def.ValueKind switch {
            FilterValueKind.Bool => "true",
            FilterValueKind.Select => OptionsFor(def) is { Count: > 0 } o ? o[0].Value : "",
            _ => ""
        };
    }

    private void OnRowChanged(int index) => EnsureTrailingRow();

    private void OnOrRowChanged(int index) {
    }

    // The grid always keeps one blank trailing AND row; filling it appends another.
    private void EnsureTrailingRow() {
        var last = _rows[^1].Cond;
        if (!string.IsNullOrEmpty(last.TopLevel))
            _rows.Add(new Row());
    }

    private void AddOr(int index) {
        if (OrAddDisabled(index))
            return;
        _rows[index].Or.Add(new FilterCondition());
    }

    private void RemoveRow(int index) {
        _rows.RemoveAt(index);
        if (_rows.Count == 0)
            _rows.Add(new Row());
    }

    private void RemoveOr(int index, int orIndex) => _rows[index].Or.RemoveAt(orIndex);

    /// <summary>
    ///     Current filter as the legacy (and, orFilters) shape, incomplete rows dropped. For embedded use, read on the
    ///     host's save.
    /// </summary>
    public LegacyFilter BuildFilter() {
        var and = new List<FilterCondition>();
        var or = new List<IReadOnlyList<FilterCondition>?>();

        foreach (var row in _rows) {
            if (!RowComplete(row.Cond))
                continue;
            and.Add(Clone(row.Cond));
            var siblings = row.Or.Where(RowComplete).Select(Clone).ToList();
            or.Add(siblings.Count > 0 ? siblings : null);
        }

        return new LegacyFilter(and, or);
    }

    private async Task ApplyAsync() => await OnApply.InvokeAsync(BuildFilter());
    private static FilterCondition Clone(FilterCondition c) => new(c.TopLevel, c.Op, c.Val);
}
