@*
    Visual grid size picker. Port of ReportGridSizePicker.vue: an 8 x 4 cell grid
    where hovering/clicking selects width x height. Two-way bound via Width/Height
    plus their changed callbacks.
*@

<div class="size-picker">
    <div class="size-grid">
        @for (int r = 1; r <= MaxRows; r++)
        {
            @for (int c = 1; c <= MaxCols; c++)
            {
                int cc = c;
                int rr = r;
                <button type="button"
                        class="size-cell @(IsActive(cc, rr) ? "active" : "")"
                        @onclick="() => Select(cc, rr)">
                </button>
            }
        }
    </div>
    <div class="size-label">@Width x @Height</div>
</div>

@code {
    private const int MaxCols = 8;
    private const int MaxRows = 4;

    [Parameter]
    public int Width { get; set; } = 2;

    [Parameter]
    public EventCallback<int> WidthChanged { get; set; }

    [Parameter]
    public int Height { get; set; } = 2;

    [Parameter]
    public EventCallback<int> HeightChanged { get; set; }

    private bool IsActive(int c, int r) => c <= Width && r <= Height;

    private async Task Select(int c, int r)
    {
        await WidthChanged.InvokeAsync(c);
        await HeightChanged.InvokeAsync(r);
    }
}
