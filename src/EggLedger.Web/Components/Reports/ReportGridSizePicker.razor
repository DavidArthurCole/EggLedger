@* Visual 8 x 4 grid size picker; clicking a cell selects width x height. Two-way bound. *@

<div class="flex flex-col gap-2">
    <div class="flex flex-col gap-0.5 self-start">
        @for (var r = 1; r <= MaxRows; r++) {
            var rr = r;
            <div class="flex gap-0.5">
                @for (var c = 1; c <= MaxCols; c++) {
                    var cc = c;
                    <button type="button"
                            class="w-3.5 h-3.5 rounded-sm border cursor-pointer transition-colors @(IsActive(cc, rr) ? "bg-indigo-600 border-indigo-500" : "bg-gray-800 border-gray-600 hover:border-gray-400")"
                            @onclick="() => Select(cc, rr)">
                    </button>
                }
            </div>
        }
    </div>
    <span class="text-xs text-gray-500">@Width x @Height</span>
</div>

@code {
    private const int MaxCols = 8;
    private const int MaxRows = 4;
    [Parameter] public int Width { get; set; } = 2;
    [Parameter] public EventCallback<int> WidthChanged { get; set; }
    [Parameter] public int Height { get; set; } = 2;
    [Parameter] public EventCallback<int> HeightChanged { get; set; }

    private bool IsActive(int c, int r) {
        return c <= Width && r <= Height;
    }

    private async Task Select(int c, int r) {
        await WidthChanged.InvokeAsync(c);
        await HeightChanged.InvokeAsync(r);
    }

}
