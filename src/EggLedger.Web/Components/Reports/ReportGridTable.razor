@using System.Globalization
@using EggLedger.Domain.Reports
@* Plain label/value table for the "grid" display mode. Port of Vue ReportVisualGrid.vue. *@

<div class="w-full h-full overflow-y-auto">
    <table class="w-full text-xs">
        <tbody>
        @for (var i = 0; i < Result.Labels.Count; i++) {
            var index = i;
            <tr class="border-b border-gray-800">
                <td class="py-0.5 pr-2 text-gray-400 truncate max-w-xs">@Result.Labels[index]</td>
                <td class="py-0.5 text-right font-mono text-gray-300">@FormatValue(index)</td>
            </tr>
        }
        </tbody>
    </table>
    @if (!string.IsNullOrEmpty(UnitLabel)) {
        <div class="text-xs text-gray-600 text-right mt-0.5">@UnitLabel</div>
    }
</div>

@code {
    [Parameter] [EditorRequired] public ReportResult Result { get; set; } = new();
    [Parameter] public string? UnitLabel { get; set; }

    private string FormatValue(int i) {
        if (Result.IsFloat) {
            var v = i < Result.FloatValues.Count ? Result.FloatValues[i] : 0;
            return v.ToString("0.00", CultureInfo.InvariantCulture);
        }

        return i < Result.Values.Count ? Result.Values[i].ToString(CultureInfo.InvariantCulture) : "0";
    }

}
