@using EggLedger.Domain.Reports
@* Dispatches a report definition + result to the matching chart by displayMode.
   Empty results show a placeholder. *@

@if (IsEmpty) {
    <div class="h-full flex items-center justify-center">
        <span class="text-xs text-gray-600 italic">No data for this report.</span>
    </div>
} else {
    switch (Def.DisplayMode) {
        case "heatmap":
            <ReportHeatmap Result="Result" Color="ColorOr" NormalizeBy="NormalizeOr"
                           UnfilledColor="@Def.UnfilledColor" MinSampleSize="Def.MinSampleSize"/>
            break;
        case "grouped_bar":
            <ReportGroupedBar Result="Result" Color="ColorOr" NormalizeBy="NormalizeOr"/>
            break;
        case "multi_line":
            <ReportMultiLineChart Result="Result" Color="ColorOr"
                                  LabelColors="@Def.LabelColors" NormalizeBy="NormalizeOr"/>
            break;
        case "pie":
            <ReportPieChart Result="FilteredResult" Color="ColorOr" LabelColors="@Def.LabelColors"/>
            break;
        case "line":
            <ReportLineChart Result="FilteredResult" Color="ColorOr"
                             UnitLabel="@NormalizeLabel" ChartType="@Def.ChartType"/>
            break;
        case "grid":
            <ReportGridTable Result="FilteredResult" UnitLabel="@NormalizeLabel"/>
            break;
        default:
            <ReportBarChart Result="FilteredResult" Color="ColorOr" UnitLabel="@NormalizeLabel"
                            LabelColors="@Def.LabelColors" ChartType="@Def.ChartType"/>
            break;
    }
}

@code {
    [Parameter] [EditorRequired] public ReportDefinition Def { get; set; } = new();
    [Parameter] [EditorRequired] public ReportResult Result { get; set; } = new();

    private bool IsEmpty =>
        FilteredResult.Labels.Count == 0
        && Result.RowLabels.Count == 0
        && Result.MatrixValues.Count == 0;

    private string ColorOr => string.IsNullOrEmpty(Def.Color) ? "#6366f1" : Def.Color;
    private string NormalizeOr => string.IsNullOrEmpty(Def.NormalizeBy) ? "none" : Def.NormalizeBy;

    // 1D display modes (bar/line/pie) apply the value filter client-side; 2D modes
    // (heatmap/grouped_bar/multi_line) ignore it (ValueFilter.Apply is a no-op on Is2D).
    private ReportResult FilteredResult => ValueFilter.Apply(Result, Def.ValueFilterOp, Def.ValueFilterThreshold);

    private string? NormalizeLabel => Def.NormalizeBy switch {
        "row_pct" or "col_pct" or "global_pct" => "%",
        "launches" => "per launch",
        "airtime" => "per flight hour",
        _ => null
    };

}
