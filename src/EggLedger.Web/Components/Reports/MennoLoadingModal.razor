@inject IJSRuntime Js

@*
    Loading modal shown while the Menno community drop-rate aggregate downloads.
    Port of MennoLoadingModal.vue as a native <dialog>. The Vue version renders
    byte-level download progress from a streamed Go fetch; MennoService.RefreshAsync
    in the browser is a single awaitable with no progress plumbing, so this shows a
    spinner while the await runs. Open it before the await, close it after.
*@

<dialog @ref="_dialog" class="menno-loading">
    <div class="menno-body">
        <span class="menno-title">Data Refresh in Progress</span>
        <hr class="menno-rule" />
        <p class="menno-text">
            <a class="url-link" target="_blank" rel="noopener"
               href="https://github.com/menno-egginc/eggincdatacollection-docs/blob/main/DataEndpoints.md">Menno's Ship Data</a>
            is currently being loaded. This data is used to provide further insights
            into the drops of your ships, and how "lucky" you've been.
        </p>
        <hr class="menno-rule" />
        <div class="menno-spinner-row">
            <img class="menno-spinner" src="@ContentPaths.Asset("images/loading.gif")" alt="Loading..." />
            <span class="menno-phase">Loading community data...</span>
        </div>
    </div>
</dialog>

@code {
    private ElementReference _dialog;
    private IJSObjectReference? _module;

    private async ValueTask<IJSObjectReference> ModuleAsync() =>
        _module ??= await Js.InvokeAsync<IJSObjectReference>("import", "./_content/EggLedger.Web/js/dialog.js");

    /// <summary>Shows the modal (call before awaiting the download).</summary>
    public async Task OpenAsync()
    {
        var module = await ModuleAsync();
        await module.InvokeVoidAsync("showModal", _dialog);
    }

    /// <summary>Closes the modal (call after the download resolves or fails).</summary>
    public async Task CloseAsync()
    {
        var module = await ModuleAsync();
        await module.InvokeVoidAsync("close", _dialog);
    }
}
