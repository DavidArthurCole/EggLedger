@* Spinner modal shown while the Menno community aggregate downloads. Blazor-controlled
   overlay (full-screen fixed backdrop + centered panel). NOT a native <dialog>.showModal():
   top-layer promotion desyncs the Blazor Server render tree (insertBefore/parentNode-null
   crashes). Non-dismissable: no backdrop click close. Open before the await, close after. *@

@if (_open) {
    <div class="fixed inset-0 z-40 flex items-center justify-center bg-black/60">
        <div class="menno-loading">
            <div class="menno-body">
                <span class="menno-title">Data Refresh in Progress</span>
                <hr class="menno-rule"/>
                <p class="menno-text">
                    <a class="url-link" target="_blank" rel="noopener"
                       href="https://github.com/menno-egginc/eggincdatacollection-docs/blob/main/DataEndpoints.md">
                        Menno's Ship Data
                    </a>
                    is currently being loaded. This data is used to provide further insights
                    into the drops of your ships, and how "lucky" you've been.
                </p>
                <hr class="menno-rule"/>
                <div class="menno-spinner-row">
                    <img class="menno-spinner" src="@ContentPaths.Asset("images/loading.gif")" alt="Loading..."/>
                    <span class="menno-phase">Loading community data...</span>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _open;

    public Task OpenAsync() {
        _open = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    public Task CloseAsync() {
        _open = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

}
