@inject IndexedDbReportStore Store
@inject IDownloadService Downloader
@inject IJSRuntime Js
@using System.Text.Json
@using EggLedger.Domain.Reports
@using EggLedger.Web.Data
@using EggLedger.Web.Services
@implements IAsyncDisposable

@* Dashboard grid of report cards, positioned via ReportGridLayout packing. Drag-reorder
   is a simple index swap (drop onto a card swaps its position with the dragged one);
   the Vue zone-insertion drag math is not replicated. *@

<div @ref="_gridRef" class="flex-1 min-h-0 overflow-y-auto pt-0 pb-2 px-3 flex flex-col gap-3">
    @if (!string.IsNullOrEmpty(_actionMessage)) {
        <span class="text-xs text-gray-400 self-end">@_actionMessage</span>
    }
    @if (_defs.Count == 0) {
        <div class="text-xs text-gray-500 text-center mt-8">No reports yet. Click "New Report" to create one.</div>
    } else {
        var (positions, _) = ReportGridLayout.BuildOccupancyFromLayout(_defs);
        <div class="grid gap-3 relative" style="grid-template-columns: repeat(8, 1fr); grid-auto-rows: @(_rowHeightPx)px;">
            @for (var i = 0; i < _defs.Count; i++) {
                var index = i;
                var def = _defs[i];
                var pos = positions[i];
                <div @key="def.Id" draggable="@EditMode" class="@(EditMode ? "cursor-grab" : "")"
                     style="grid-column: @pos.Col / span @pos.W; grid-row: @pos.Row / span @pos.H;"
                     @ondragstart="() => OnDragStart(index)" @ondragover="@(() => { })" @ondragover:preventDefault="true"
                     @ondrop="() => OnDropAsync(index)">
                    <ReportCard Def="def" Pos="pos" AccountId="@AccountId"
                                EditMode="EditMode" Groups="Groups" OnEdit="OnEdit"
                                OnDelete="HandleDeleteAsync" OnChanged="ReloadAsync"/>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] [EditorRequired] public string AccountId { get; set; } = "";

    [Parameter]
    public string? GroupFilter { get; set; }

    [Parameter] public bool EditMode { get; set; }
    [Parameter] public IReadOnlyList<ReportGroupRow> Groups { get; set; } = Array.Empty<ReportGroupRow>();
    [Parameter] public EventCallback<ReportDefinition> OnEdit { get; set; }
    private List<ReportDefinition> _defs = new();
    private string _loadedKey = "";
    private int? _draggingIndex;
    private string? _actionMessage;
    private ElementReference _gridRef;
    private IJSObjectReference? _module;
    private IJSObjectReference? _observerHandle;
    private DotNetObjectReference<ReportGrid>? _selfRef;
    private int _rowHeightPx = 144;

    protected override async Task OnParametersSetAsync() {
        var key = AccountId + "|" + (GroupFilter ?? "");
        if (key == _loadedKey) {
            return;
        }

        _loadedKey = key;
        await ReloadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) {
            _selfRef = DotNetObjectReference.Create(this);
            _module = await Js.InvokeAsync<IJSObjectReference>("import", "./_content/EggLedger.Web/js/reportGrid.js");
            _observerHandle = await _module.InvokeAsync<IJSObjectReference>("observe", _gridRef, _selfRef);
        }
    }

    [JSInvokable]
    public void OnGridResized(double width) {
        var next = ReportGridLayout.ComputeRowHeightPx(width);
        if (next != _rowHeightPx) {
            _rowHeightPx = next;
            StateHasChanged();
        }
    }

    public async Task ReloadAsync() {
        if (string.IsNullOrEmpty(AccountId)) {
            _defs = new List<ReportDefinition>();
            return;
        }

        var rows = await Store.RetrieveAccountReportsAsync(AccountId);
        var filtered = GroupFilter is null
            ? rows
            : rows.Where(r => r.GroupId == GroupFilter).ToList();
        _defs = filtered.Select(ReportMapping.ToDefinition).ToList();
        StateHasChanged();
    }

    private async Task HandleDeleteAsync(string id) {
        await Store.DeleteReportAsync(id);
        await ReloadAsync();
    }

    private void OnDragStart(int index) {
        _draggingIndex = index;
    }

    private async Task OnDropAsync(int targetIndex) {
        var from = _draggingIndex;
        _draggingIndex = null;
        if (from is null || from == targetIndex) {
            return;
        }

        var ids = _defs.Select(d => d.Id).ToList();
        var moved = ids[from.Value];
        ids.RemoveAt(from.Value);
        ids.Insert(targetIndex, moved);
        await Store.ReorderReportsAsync(ids);
        await ReloadAsync();
    }

    public async Task ExportAllAsync() {
        var rows = await Store.RetrieveAccountReportsAsync(AccountId);
        var defs = rows.Select(ReportMapping.ToDefinition).ToList();
        var json = JsonSerializer.Serialize(defs, new JsonSerializerOptions { WriteIndented = true });
        await Downloader.DownloadJsonAsync(json, $"reports-export-{DateTimeOffset.UtcNow:yyyyMMdd-HHmmss}.json");
        _actionMessage = $"Exported {defs.Count} report(s)";
        StateHasChanged();
        ClearMessageLater();
    }

    public async Task ImportAsync() {
        var json = await Downloader.PickJsonFileAsync();
        if (string.IsNullOrWhiteSpace(json)) {
            return;
        }

        try {
            var defs = ParseImportedDefinitions(json);
            foreach (var def in defs) {
                def.Id = Guid.NewGuid().ToString("D");
                def.AccountId = AccountId;
                def.SortOrder = 0;
                def.CreatedAt = 0;
                def.UpdatedAt = 0;
                if (GroupFilter is not null) {
                    def.GroupId = GroupFilter;
                }

                await Store.InsertReportAsync(ReportMapping.ToRow(def));
            }

            _actionMessage = $"Imported {defs.Count} report(s)";
        }
        catch (JsonException) {
            _actionMessage = "Import failed - invalid file";
        }

        await ReloadAsync();
        ClearMessageLater();
    }

    private static List<ReportDefinition> ParseImportedDefinitions(string json) {
        var trimmed = json.TrimStart();
        if (trimmed.StartsWith('[')) {
            return JsonSerializer.Deserialize<List<ReportDefinition>>(json) ?? new List<ReportDefinition>();
        }

        var single = JsonSerializer.Deserialize<ReportDefinition>(json);
        return single is null ? new List<ReportDefinition>() : new List<ReportDefinition> { single };
    }

    private void ClearMessageLater() {
        _ = ClearMessageLaterAsync();
    }

    private async Task ClearMessageLaterAsync() {
        await Task.Delay(5000);
        _actionMessage = null;
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync() {
        if (_observerHandle is not null && _module is not null) {
            await _module.InvokeVoidAsync("unobserve", _observerHandle);
            await _observerHandle.DisposeAsync();
        }

        if (_module is not null) {
            await _module.DisposeAsync();
        }

        _selfRef?.Dispose();
    }

}
