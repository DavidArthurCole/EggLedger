@using System.Globalization
@using EggLedger.Domain.Reports
@using EggLedger.Domain.Reports.Charts
@implements IAsyncDisposable
@inject IJSRuntime Js
@* Line / area chart; geometry from ChartGeometry. viewBox tracks the container's actual
   rendered size via ResizeObserver (reportChart.js) so geometry is never CSS-distorted.
   SVG <text> is emitted via MarkupString helpers because Razor reserves the bare
   <text> tag for its own text-transition control block. *@

<div class="h-full w-full" @ref="_containerRef">
    @if (!_measured) {
        <div class="h-full flex items-center justify-center">
            <span class="text-xs text-gray-500 animate-pulse">Loading chart...</span>
        </div>
    } else if (Points().Count >= 2) {
        var pts = Points();
        var max = MaxVal();
        var ticks = ChartGeometry.YTicks(max, _h, Result.IsFloat);
        <svg viewBox="0 0 @Fmt(_w) @Fmt(_h)" preserveAspectRatio="xMidYMid meet" class="w-full h-full overflow-visible">
            <defs>
                <linearGradient id="@_gradId" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="@Color" stop-opacity="0.3"/>
                    <stop offset="100%" stop-color="@Color" stop-opacity="0.02"/>
                </linearGradient>
            </defs>

            @if (max > 0) {
                @foreach (var tick in ticks) {
                    <line x1="@Fmt(ChartGeometry.PadLeft)" y1="@Fmt(tick.Y)"
                          x2="@Fmt(_w - ChartGeometry.PadRight)" y2="@Fmt(tick.Y)"
                          stroke="#374151" stroke-dasharray="3 3" stroke-width="0.5"/>
                    @YTickText(tick)
                }
            }

            @if (ChartType != "line") {
                <path d="@ChartGeometry.AreaPath(pts, _h)" fill="url(#@_gradId)"/>
            }

            <polyline points="@ChartGeometry.PolylinePoints(pts)" fill="none"
                      stroke="@Color" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"/>

            @foreach (var p in ChartGeometry.ThinLabels(pts)) {
                @XLabelText(p)
            }

            @foreach (var p in pts) {
                <circle cx="@Fmt(p.X)" cy="@Fmt(p.Y)" r="2.5" fill="@Color"/>
                <circle class="chart-hit" cx="@Fmt(p.X)" cy="@Fmt(p.Y)" r="7" fill="transparent"
                        style="cursor: pointer;" data-tt="@PointTip(p)"/>
            }
        </svg>
    } else {
        <div class="h-full flex items-center justify-center">
            <span class="text-xs text-gray-600 italic">Not enough data for a line chart</span>
        </div>
    }
</div>

@code {
    private double _w = 300;
    private double _h = 150;
    private bool _measured;
    private ElementReference _containerRef;
    private IJSObjectReference? _module;
    private IJSObjectReference? _observerHandle;
    private DotNetObjectReference<ReportLineChart>? _selfRef;
    private readonly string _gradId = "line-grad-" + Guid.NewGuid().ToString("N").Substring(0, 5);
    [Parameter] [EditorRequired] public ReportResult Result { get; set; } = new();
    [Parameter] [EditorRequired] public string Color { get; set; } = "#6366f1";
    [Parameter] public string? UnitLabel { get; set; }

    [Parameter]
    public string? ChartType { get; set; }

    private string UnitSuffix => string.IsNullOrEmpty(UnitLabel) ? "" : " " + UnitLabel;

    private List<double> Values() {
        return ChartGeometry.Values(Result.Values, Result.FloatValues, Result.IsFloat);
    }

    private double MaxVal() {
        return Values().DefaultIfEmpty(0).Max();
    }

    private List<ChartPoint> Points() {
        return ChartGeometry.Points(Values(), Result.Labels, _w, _h);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender) {
            _selfRef = DotNetObjectReference.Create(this);
            _module = await Js.InvokeAsync<IJSObjectReference>("import", "./_content/EggLedger.Web/js/reportChart.js");
            _observerHandle = await _module.InvokeAsync<IJSObjectReference>("observe", _containerRef, _selfRef);
        }
    }

    [JSInvokable]
    public void OnChartResized(double width, double height) {
        _w = width > 0 ? width : 300;
        _h = height > 0 ? height : 150;
        _measured = true;
        StateHasChanged();
    }

    private MarkupString YTickText(YTick tick) {
        var x = Fmt(ChartGeometry.PadLeft - 4);
        var y = Fmt(tick.Y);
        return new MarkupString(
            $"<text x=\"{x}\" y=\"{y}\" text-anchor=\"end\" dominant-baseline=\"middle\" style=\"font-size: 10px; fill: #6b7280;\">{Esc(tick.Label)}</text>");
    }

    private MarkupString XLabelText(ChartPoint p) {
        var tx = Fmt(p.X);
        var ty = Fmt(_h - ChartGeometry.PadBottom + 4);
        var label = Esc(ChartGeometry.FormatXLabel(p.Label));
        return new MarkupString(
            $"<text transform=\"translate({tx}, {ty}) rotate(-45)\" text-anchor=\"end\" style=\"font-size: 10px; fill: #6b7280;\">{label}</text>");
    }

    private string FormatValue(double v) {
        return Result.IsFloat
            ? v.ToString("0.00", CultureInfo.InvariantCulture)
            : Math.Round(v).ToString(CultureInfo.InvariantCulture);
    }

    private string PointTip(ChartPoint p) {
        return $"{p.Label}\n{FormatValue(p.Value)}{UnitSuffix}";
    }

    private static string Fmt(double v) {
        return v.ToString("0.###", CultureInfo.InvariantCulture);
    }

    private static string Esc(string s) {
        return ChartGeometry.EscapeText(s);
    }

    public async ValueTask DisposeAsync() {
        if (_observerHandle is not null && _module is not null) {
            await _module.InvokeVoidAsync("unobserve", _observerHandle);
            await _observerHandle.DisposeAsync();
        }

        if (_module is not null) {
            await _module.DisposeAsync();
        }

        _selfRef?.Dispose();
    }

}
