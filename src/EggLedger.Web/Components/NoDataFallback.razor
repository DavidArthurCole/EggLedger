@inject NavigationManager Nav

@*
    Empty-state box shown when a view has no mission data yet. Port of
    www/src/components/NoDataFallback.vue: directs the user to the Ledger tab to
    fetch. Vue emits a navigate event; here the Ledger tab is a real route, so the
    button navigates to "/".
*@
<div class="text-center mt-3 rounded-md border border-red-700 py-2">
    <span class="text-red-700">
        @Message<br />Please <b>Fetch</b> from the
    </span>
    <button type="button" class="btn-link" @onclick="GoToLedger">
        <span class="text-blue-500 ledger-underline font-bold">Ledger tab</span>
    </button>
    <span class="text-red-700"> and then come back here.</span>
</div>

@code {
    [Parameter]
    public string Message { get; set; } = "No mission data has been loaded yet.";

    private void GoToLedger() => Nav.NavigateTo("/");
}
