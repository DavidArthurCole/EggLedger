@page "/admin"
@using EggLedger.Web.Components.Admin
@using EggLedger.Web.Services
@using EggLedger.Web.Settings
@using Microsoft.Extensions.DependencyInjection
@inject AdminService Admin
@inject CloudSessionStore SessionStore
@inject AdminState AdminState
@inject IServiceProvider Services

<PageTitle>EggLedger - Admin</PageTitle>

<section class="view-layout overflow-auto">
    @if (_token is null) {
        <p class="text-gray-400 italic mt-0_5rem">Connect cloud sync on the Settings tab to access admin.</p>
    } else if (!_isAdmin) {
        <p class="text-red-700 italic mt-0_5rem">Admin access required.</p>
    } else {
        <div class="admin-grid">
            <div>
                @if (Services.GetService<IBotConfigSlot>() is { } botSlot) {
                    @botSlot.Render()
                }
                <AdminTrafficPanel Metrics="_metrics"/>
            </div>
            <div>
                <AdminUsersPanel Users="_users" OnDelete="DeleteUser" Error="_error"/>
            </div>
        </div>
    }
</section>

@code {
    private string? _token;
    private bool _isAdmin;
    private IReadOnlyList<AdminUser>? _users;
    private AdminMetrics? _metrics;
    private string _error = "";

    protected override async Task OnInitializedAsync() {
        var session = await SessionStore.GetSessionAsync();
        _token = session?.Token;
        if (_token is null) return;

        _isAdmin = await Admin.IsAdminAsync(_token);
        AdminState.IsAdmin = _isAdmin;
        if (_isAdmin) await RefreshAsync();
    }

    private async Task RefreshAsync() {
        if (_token is null) return;
        _users = await Admin.GetUsersAsync(_token);
        _metrics = await Admin.GetMetricsAsync(_token);
        StateHasChanged();
    }

    private async Task DeleteUser(Guid userId) {
        if (_token is null) return;
        if (await Admin.DeleteUserAsync(_token, userId)) await RefreshAsync();
        else _error = $"failed to delete {userId}";
    }

}
