@page "/admin"
@using EggLedger.Web.Services
@using EggLedger.Web.Settings
@using EggLedger.Web.State
@inject AdminService Admin
@inject CloudSessionStore SessionStore
@inject AdminState AdminState

<PageTitle>EggLedger - Admin</PageTitle>

<section class="view-layout overflow-auto">
    @if (_token is null) {
        <p class="text-gray-400 italic mt-0_5rem">Connect cloud sync on the Settings tab to access admin.</p>
    } else if (!_isAdmin) {
        <p class="text-red-700 italic mt-0_5rem">Admin access required.</p>
    } else {
        <span class="section-heading">Traffic (last hour)</span>
        @if (_metrics is { Minutes.Count: > 0 }) {
            <div class="flex items-end gap-px h-24 mt-0_5rem bg-darkest rounded-md p-2">
                @{ var max = Math.Max(1, _metrics.Minutes.Max(m => m.Total)); }
                @foreach (var m in _metrics.Minutes) {
                    <div class="flex-1 bg-blue-500 rounded-sm" style="height: @(m.Total * 100 / max)%" title="@m.Total req"></div>
                }
            </div>
            <div class="text-xs text-gray-500 mt-1">@_metrics.Minutes.Sum(m => m.Total) requests in the last 60 minutes</div>

            <span class="section-heading mt-1rem">Requests by endpoint</span>
            <table class="w-full text-xs text-gray-400 mt-0_5rem tabular-nums">
                <tbody>
                    @foreach (var p in _metrics.Paths) {
                        <tr><td class="font-mono py-0.5">@p.Path</td><td class="text-right">@p.Count</td></tr>
                    }
                </tbody>
            </table>
        } else {
            <p class="text-gray-500 italic mt-0_5rem">No traffic recorded yet.</p>
        }

        @if (_metrics is { Spam.Count: > 0 }) {
            <span class="section-heading mt-1rem">Potentially identified spam (@_metrics.Spam.Count)</span>
            <div class="text-xs text-gray-500 mt-0_5rem">Invalid /api/v1 requests (no matching route). Likely scanners probing for other software.</div>
            <table class="w-full text-xs text-gray-400 mt-0_5rem tabular-nums">
                <thead>
                    <tr class="text-gray-500">
                        <th class="text-left py-1">IP</th>
                        <th class="text-left">Request</th>
                        <th class="text-left">User-Agent</th>
                        <th class="text-right">Hits</th>
                        <th class="text-right">Last seen</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in _metrics.Spam) {
                        <tr class="border-t border-gray-700/50">
                            <td class="py-1 font-mono">@s.Ip</td>
                            <td class="font-mono">@s.Method @s.Path</td>
                            <td class="truncate max-w-xs text-gray-600" title="@s.UserAgent">@s.UserAgent</td>
                            <td class="text-right">@s.Hits</td>
                            <td class="text-right text-gray-600">@FormatEpoch(s.LastSeen)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <div class="flex items-baseline justify-between mt-1rem">
            <span class="section-heading">Users (@(_users?.Count ?? 0))</span>
            @if (_users is { Count: > 0 }) {
                <span class="text-xs text-gray-500 tabular-nums">@_users.Sum(u => u.BlobCount) blobs · @LedgerFormatting.FormatBytes(_users.Sum(u => u.StorageBytes)) total</span>
            }
        </div>
        <div class="mt-0_5rem max-h-96 overflow-auto rounded-md border border-gray-700/50">
            <table class="w-full table-fixed text-sm text-gray-400 tabular-nums">
                <colgroup>
                    <col style="width: 34%" />
                    <col style="width: 26%" />
                    <col style="width: 12%" />
                    <col style="width: 16%" />
                    <col style="width: 12%" />
                </colgroup>
                <thead class="sticky top-0 bg-darkest z-10">
                    <tr class="text-gray-500 text-xs">
                        <th class="text-left py-1 px-2">User</th>
                        <th class="text-left px-2">Discord ID</th>
                        <th class="text-right px-2">Blobs</th>
                        <th class="text-right px-2">Storage</th>
                        <th class="px-2"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in _users ?? []) {
                        <tr class="border-t border-gray-700/50">
                            <td class="py-1 px-2 font-medium truncate" title="@u.Username">@u.Username @(u.IsAdmin ? "(admin)" : "")</td>
                            <td class="px-2 font-mono text-xs text-gray-600 truncate" title="@u.DiscordId">@u.DiscordId</td>
                            <td class="text-right px-2">@u.BlobCount</td>
                            <td class="text-right px-2">@LedgerFormatting.FormatBytes(u.StorageBytes)</td>
                            <td class="text-right px-2">
                                @if (!u.IsAdmin) {
                                    <button type="button" class="text-xs text-red-400 hover:text-red-300"
                                            @onclick="() => DeleteUser(u.DiscordId)">Delete</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (_error.Length > 0) {
            <p class="text-red-500 text-xs mt-0_5rem">@_error</p>
        }
    }
</section>

@code {
    private string? _token;
    private bool _isAdmin;
    private IReadOnlyList<AdminUser>? _users;
    private AdminMetrics? _metrics;
    private string _error = "";

    protected override async Task OnInitializedAsync() {
        var session = await SessionStore.GetSessionAsync();
        _token = session?.Token;
        if (_token is null) return;

        _isAdmin = await Admin.IsAdminAsync(_token);
        AdminState.IsAdmin = _isAdmin;
        if (_isAdmin) await RefreshAsync();
    }

    private async Task RefreshAsync() {
        if (_token is null) return;
        _users = await Admin.GetUsersAsync(_token);
        _metrics = await Admin.GetMetricsAsync(_token);
        StateHasChanged();
    }

    private static string FormatEpoch(long unixSeconds) =>
        DateTimeOffset.FromUnixTimeSeconds(unixSeconds).ToLocalTime().ToString("yyyy-MM-dd HH:mm");

    private async Task DeleteUser(string discordId) {
        if (_token is null) return;
        if (await Admin.DeleteUserAsync(_token, discordId)) await RefreshAsync();
        else _error = $"failed to delete {discordId}";
    }
}
