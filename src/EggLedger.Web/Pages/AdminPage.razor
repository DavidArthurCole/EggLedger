@page "/admin"
@using EggLedger.Web.Components.Admin
@using EggLedger.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.DependencyInjection
@inject AdminState AdminState
@inject IServiceProvider Services

<PageTitle>EggLedger - Admin</PageTitle>

<section class="view-layout overflow-auto">
    @if (!_isAdmin) {
        <p class="text-red-700 italic mt-0_5rem">Admin access required.</p>
    } else {
        <div class="admin-grid">
            <div>
                @if (Services.GetService<IBotConfigSlot>() is { } botSlot) {
                    @botSlot.Render()
                }
                @if (Services.GetService<ITrafficPanelSlot>() is { } trafficSlot) {
                    @trafficSlot.Render()
                }
            </div>
            <div>
                <AdminUsersPanel Users="_users" OnDelete="DeleteUser" Error="@_error"/>
            </div>
        </div>
    }
</section>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthStateTask { get; set; }

    private bool _isAdmin;
    private Guid? _currentUserId;
    private IReadOnlyList<AdminUser>? _users;
    private string _error = "";

    protected override async Task OnInitializedAsync() {
        if (AuthStateTask is not null) {
            var authState = await AuthStateTask;
            var access = Services.GetService<IAdminAccess>();
            _isAdmin = access?.IsAdmin(authState.User) ?? false;
            _currentUserId = access?.CurrentUserId(authState.User);
        }

        AdminState.IsAdmin = _isAdmin;
        if (_isAdmin) _ = RefreshAsync();
    }

    private async Task RefreshAsync() {
        var data = Services.GetService<IAdminData>();
        if (data is null) return;
        _users = await data.GetUsersAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task DeleteUser(Guid userId) {
        if (userId == _currentUserId) {
            _error = "cannot delete your own account";
            return;
        }

        var data = Services.GetService<IAdminData>();
        if (data is null) return;
        if (await data.DeleteUserAsync(userId)) await RefreshAsync();
        else _error = $"failed to delete {userId}";
    }

}
