@page "/missions"
@using System.Diagnostics
@using System.Text.Json
@using EggLedger.Domain.MissionPacking
@using EggLedger.Domain.MissionQuery
@using EggLedger.Web.Data
@using EggLedger.Web.Missions
@using EggLedger.Web.Missions.Model
@implements IDisposable
@inject MissionQueryHandlers Queries
@inject MissionConfigProvider Config
@inject ActiveAccount Active
@inject AppStateService AppState
@inject IndexedDbSettings Settings
@inject MissionDataCache DataCache

<PageTitle>EggLedger - Mission Data</PageTitle>

<section class="flex-1 flex flex-col w-full mx-auto px-4 overflow-hidden bg-darker">
    @if (Active.ActiveAccountId is null) {
        <p class="text-gray-500 italic">Select an account on the Ledger tab to view its missions.</p>
    } else if (_loading) {
        <p class="text-gray-500 italic">Loading mission data...</p>
    } else if (_allMissions is null || _allMissions.Count == 0) {
        <NoDataFallback/>
    } else {
        <div class="flex flex-col md:flex-row md:items-stretch gap-0_75rem mt-0_75rem flex-1 min-h-0">
            <div class="filter-panel mt-0 @(_hideFilter ? "md:w-auto md:flex-none" : "md:w-[30%]")">
                <span class="mr-0_5rem h-20 font-bold text-gray-400">Filter</span>
                <button type="button" class="text-base toggle-link whitespace-nowrap" @onclick="@(() => _hideFilter = !_hideFilter)">
                    @(_hideFilter ? "Show" : "Hide")
                </button>
                @if (!_hideFilter) {
                    <MissionFilterBar FieldCtx="Config.FieldCtx"
                                      Applying="_applying"
                                      LastResultText="@_resultText"
                                      OnApply="ApplyFilterAsync"/>
                }
            </div>

            <div class="flex-1 flex flex-col min-h-0 px-2 overflow-auto shadow-sm bg-darkest rounded-md">
                <MissionResultsTable Grouping="_grouping"
                                     ViewByDate="_opts.ViewByDate"
                                     ViewMissionTimes="_opts.ViewMissionTimes"
                                     MultiViewMode="_opts.MultiViewMode"
                                     Config="_cardPresets.ActivePreset()"
                                     SelectedIds="_multiSelectedIds"
                                     TabFiltered="_tabFiltered ?? Array.Empty<DatabaseMission>()"
                                     MissionBeingViewed="_missionBeingViewed"
                                     OnViewMission="ViewMissionAsync"
                                     OnViewRow="ViewRowAsync"
                                     OnSelectionChanged="StateHasChanged"
                                     OnGroupingChanged="StateHasChanged"
                                     TileSelector="@(_hasBothTypes ? RenderTileSelector() : null)"
                                     HeaderExtra="@RenderOptionsPopover()"/>
            </div>
        </div>

        <MissionOverlay @ref="_overlay"
                        AccountId="@Active.ActiveAccountId"
                        FilteredMissions="_tabFiltered ?? Array.Empty<DatabaseMission>()"
                        SortMethod="_opts.SortMethod"
                        ShowExpectedDrops="_cardPresets.ActivePreset().ShowExpectedDropsPerShip"/>

        <MissionCardConfigModal @ref="_cardConfigModal"
                                PresetSet="_cardPresets"
                                PreviewMission="_tabFiltered?.FirstOrDefault()"
                                OnSave="SaveCardPresetSetAsync"/>
    }
</section>

@code {
    private bool _loading;
    private bool _hideFilter;
    private bool _optionsOpen;
    private bool _applying;
    private string _resultText = "";
    private string? _missionBeingViewed;
    private IReadOnlyList<DatabaseMission>? _allMissions;
    private IReadOnlyList<DatabaseMission>? _filtered;
    private IReadOnlyList<DatabaseMission>? _tabFiltered;
    private MissionGrouping? _grouping;
    private bool _hasBothTypes;
    private readonly MissionViewOptions _opts = new();
    private readonly HashSet<string> _multiSelectedIds = new();
    private MissionFilterMatcher? _matcher;
    private MissionOverlay? _overlay;
    private CardPresetSet _cardPresets = CardPresetSet.Default;
    private MissionCardConfigModal? _cardConfigModal;
    private static readonly JsonSerializerOptions CardJsonOptions = new(JsonSerializerDefaults.Web);

    // All drops keyed by mission id, loaded once on first drop-filter so the matcher
    // reads memory instead of decoding per mission. Null = not loaded yet.
    private Dictionary<string, List<MissionDrop>>? _allDrops;

    protected override async Task OnInitializedAsync() {
        Active.Changed += OnAccountChanged;
        AppState.Changed += OnAppStateChanged;
        var settings = await Settings.GetAllSettingsAsync();
        _opts.LoadFrom(settings);
        _cardPresets = settings.TryGetValue(MissionViewOptions.KeyCardPresets, out var json) && !string.IsNullOrEmpty(json)
            ? JsonSerializer.Deserialize<CardPresetSet>(json, CardJsonOptions) ?? CardPresetSet.Default
            : CardPresetSet.Default;
        await LoadAsync();
    }

    private void OnAccountChanged() {
        InvokeAsync(LoadAsync);
    }

    // Refresh on fetch completion so new missions show without a manual reload.
    private void OnAppStateChanged() {
        if (AppState.PipelineState == Services.AppState.Success && Active.ActiveAccountId is not null) {
            DataCache.InvalidateAll();
            InvokeAsync(LoadAsync);
        }
    }

    private async Task LoadAsync() {
        _missionBeingViewed = null;
        var id = Active.ActiveAccountId;
        if (id is null) {
            _allMissions = null;
            _filtered = null;
            _grouping = null;
            StateHasChanged();
            return;
        }

        _resultText = "";
        _allDrops = null;

        var cached = DataCache.GetMissions(id, DateTime.UtcNow);
        List<DatabaseMission> missions;
        if (cached is not null) {
            missions = [.. cached];
        } else {
            _loading = true;
            StateHasChanged();
            var rows = await Queries.ViewMissionsOfEidAsync(id);
            missions = rows?.Cast<DatabaseMission>().ToList() ?? new List<DatabaseMission>();
            DataCache.SetMissions(id, missions, DateTime.UtcNow);
        }

        _allMissions = missions;
        _filtered = missions;
        _hasBothTypes = MissionViewOptions.HasBothMissionTypes(missions);
        if (!_hasBothTypes) {
            _opts.MissionTypeTab = null;
        }

        _matcher = new MissionFilterMatcher(
            Config.DurationConfigs,
            id,
            DropsFetcher);
        Regroup();
        _loading = false;
        StateHasChanged();
    }

    // Serves drops from the one-shot all-drops cache; loads it on first use.
    private async Task<IReadOnlyList<MissionDrop>?> DropsFetcher(string accountId, string missionId) {
        _allDrops ??= await Queries.GetAllPlayerDropsAsync(accountId) ?? [];
        return _allDrops.TryGetValue(missionId, out var drops) ? drops : [];
    }

    private void Regroup() {
        _tabFiltered = MissionViewOptions.TabFilteredMissions(_filtered, _opts.MissionTypeTab);
        _grouping = MissionGrouper.Group(_tabFiltered, MissionFilterMatcher.LedgerDate, true);
    }

    private async Task SaveCardPresetSetAsync(CardPresetSet updated) {
        _cardPresets = updated;
        var json = JsonSerializer.Serialize(_cardPresets, CardJsonOptions);
        await Settings.SetSettingAsync(MissionViewOptions.KeyCardPresets, json);
        StateHasChanged();
    }

    private async Task ApplyFilterAsync(MissionFilterBar.LegacyFilter filter) {
        if (_allMissions is null || _matcher is null) {
            return;
        }

        _applying = true;
        StateHasChanged();

        var sw = Stopwatch.StartNew();
        var result = new List<DatabaseMission>();
        foreach (var mission in _allMissions) {
            if (await _matcher.MissionMatchesFilterAsync(mission, filter.And, filter.Or)) {
                result.Add(mission);
            }
        }

        sw.Stop();

        _filtered = result;
        PruneSelection();
        var shown = result.Count;
        var filteredOut = _allMissions.Count - shown;
        _resultText = $"Filtered in {sw.Elapsed.TotalSeconds:0.###}s ({shown} shown, {filteredOut} filtered out)";
        Regroup();
        _applying = false;
        StateHasChanged();
    }

    private void PruneSelection() {
        if (_filtered is null) {
            _multiSelectedIds.Clear();
            return;
        }

        var valid = new HashSet<string>();
        foreach (var m in _filtered) {
            valid.Add(m.MissiondId);
        }

        _multiSelectedIds.RemoveWhere(id => !valid.Contains(id));
    }

    private void SelectTab(int? tab) {
        _opts.MissionTypeTab = tab;
        Regroup();
        StateHasChanged();
    }

    private RenderFragment RenderTileSelector() => __builder => {
        <div class="tile-group">
            <button type="button" class="tile-group-item @(_opts.MissionTypeTab is null ? "bg-darkest text-gray-200 border-gray-500" : "bg-darker text-gray-400 border-gray-700 hover:bg-dark_tab_hover")" @onclick="@(() => SelectTab(null))">All <span class="text-gray-500 ml-1">(@(_filtered?.Count ?? 0))</span></button>
            <button type="button" class="tile-group-item @(_opts.MissionTypeTab == 0 ? "bg-darkest text-gray-200 border-gray-500" : "bg-darker text-gray-400 border-gray-700 hover:bg-dark_tab_hover")" @onclick="@(() => SelectTab(0))">Home <span class="text-gray-500 ml-1">(@CountOfType(0))</span></button>
            <button type="button" class="tile-group-item @(_opts.MissionTypeTab == 1 ? "bg-darkest text-gray-200 border-gray-500" : "bg-darker text-gray-400 border-gray-700 hover:bg-dark_tab_hover")" @onclick="@(() => SelectTab(1))">Virtue <span class="text-gray-500 ml-1">(@CountOfType(1))</span></button>
        </div>
    };

    private RenderFragment RenderOptionsPopover() => __builder => {
        <div class="relative">
            <button type="button" class="text-base toggle-link" @onclick="@(() => _cardConfigModal!.OpenAsync())">
                Card Design
            </button>
            <button type="button" class="text-base toggle-link" @onclick="@(() => _optionsOpen = !_optionsOpen)">
                Options
            </button>
            @if (_optionsOpen) {
                <div class="absolute right-0 top-full mt-1 z-40 w-72 max-w-[90vw] px-3 py-2 shadow-sm text-sm text-gray-400 bg-darkest border border-gray-700 rounded-md tabular-nums">
                    <div class="flex flex-col gap-3">
                        <div>
                            <span class="font-bold text-gray-400">Display</span>
                            <div class="flex flex-col gap-1 mt-1">
                                <label><input type="checkbox" class="ext-opt-check mr-0_5rem" checked="@_opts.ViewByDate" @onchange="@(e => SetOpt(MissionViewOptions.KeyViewByDate, b => _opts.ViewByDate = b, e))"/> Separate missions by day</label>
                                <label><input type="checkbox" class="ext-opt-check mr-0_5rem" checked="@_opts.ViewMissionTimes" @onchange="@(e => SetOpt(MissionViewOptions.KeyViewTimes, b => _opts.ViewMissionTimes = b, e))"/> Show launch times</label>
                            </div>
                        </div>
                        <div>
                            <span class="font-bold text-gray-400">Multi-View Method</span>
                            <div class="tile-group flex-wrap mt-1">
                                <button type="button" class="tile-group-item @(_opts.MultiViewMode == MultiViewMode.Off ? "bg-darkest text-gray-200 border-gray-500" : "bg-darker text-gray-400 border-gray-700 hover:bg-dark_tab_hover")" @onclick="@(() => SetMultiView(MultiViewMode.Off))">Off</button>
                                <button type="button" class="tile-group-item @(_opts.MultiViewMode == MultiViewMode.Row ? "bg-darkest text-gray-200 border-gray-500" : "bg-darker text-gray-400 border-gray-700 hover:bg-dark_tab_hover")" @onclick="@(() => SetMultiView(MultiViewMode.Row))">Row/Date Select</button>
                                <button type="button" class="tile-group-item @(_opts.MultiViewMode == MultiViewMode.Free ? "bg-darkest text-gray-200 border-gray-500" : "bg-darker text-gray-400 border-gray-700 hover:bg-dark_tab_hover")" @onclick="@(() => SetMultiView(MultiViewMode.Free))">Free Select</button>
                            </div>
                        </div>
                        <div>
                            <span class="font-bold text-gray-400">Drops Sort Method</span>
                            <div class="tile-group flex-wrap mt-1">
                                <button type="button" class="tile-group-item @(_opts.SortMethod == MissionSortMethod.Default ? "bg-darkest text-gray-200 border-gray-500" : "bg-darker text-gray-400 border-gray-700 hover:bg-dark_tab_hover")" @onclick="@(() => SetSortMethod(MissionSortMethod.Default))">Default</button>
                                <button type="button" class="tile-group-item @(_opts.SortMethod == MissionSortMethod.Iv ? "bg-darkest text-gray-200 border-gray-500" : "bg-darker text-gray-400 border-gray-700 hover:bg-dark_tab_hover")" @onclick="@(() => SetSortMethod(MissionSortMethod.Iv))">Inventory Visualizer</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    };

    private int CountOfType(int type) {
        if (_filtered is null) {
            return 0;
        }

        var n = 0;
        foreach (var m in _filtered) {
            if (m.MissionType == type) {
                n++;
            }
        }

        return n;
    }

    private async Task SetOpt(string key, Action<bool> apply, ChangeEventArgs e) {
        var value = e.Value is bool b ? b : bool.TryParse(e.Value?.ToString(), out var parsed) && parsed;
        apply(value);
        await Settings.SetSettingAsync(key, value ? "true" : "false");
        StateHasChanged();
    }

    private async Task SetMultiView(MultiViewMode mode) {
        _opts.MultiViewMode = mode;
        _multiSelectedIds.Clear();
        await Settings.SetSettingAsync(MissionViewOptions.KeyMultiViewMode, MissionViewOptions.MultiViewModeToString(mode));
        StateHasChanged();
    }

    private async Task SetSortMethod(MissionSortMethod method) {
        _opts.SortMethod = method;
        await Settings.SetSettingAsync(MissionViewOptions.KeySortMethod, MissionViewOptions.SortMethodToString(method));
        if (_overlay is not null) {
            await _overlay.ReSortAsync(method);
        }

        StateHasChanged();
    }

    private async Task ViewMissionAsync(string missionId) {
        _missionBeingViewed = missionId;
        StateHasChanged();
        if (_overlay is not null) {
            await _overlay.OpenAsync(missionId);
        }
    }

    // Row/Date and Free Select both funnel here: one id opens single, many open the multi grid.
    private async Task ViewRowAsync(IReadOnlyList<string> missionIds) {
        if (missionIds.Count == 0 || _overlay is null) {
            return;
        }

        if (missionIds.Count == 1) {
            await ViewMissionAsync(missionIds[0]);
            return;
        }

        _missionBeingViewed = null;
        StateHasChanged();
        await _overlay.OpenMultiAsync(missionIds);
    }

    public void Dispose() {
        Active.Changed -= OnAccountChanged;
        AppState.Changed -= OnAppStateChanged;
    }

}
