@page "/lifetime"
@using System.Diagnostics
@using EggLedger.Domain.MissionPacking
@using EggLedger.Domain.MissionQuery
@using EggLedger.Web.Data
@using EggLedger.Web.Missions
@implements IDisposable
@inject MissionQueryHandlers Queries
@inject MissionConfigProvider Config
@inject ActiveAccount Active
@inject AppStateService AppState
@inject IndexedDbSettings Settings
@inject MissionDataCache DataCache

<PageTitle>EggLedger - Lifetime Data</PageTitle>

<section class="flex-1 flex flex-col w-full mx-auto px-4 overflow-hidden bg-darker">
    @if (Active.ActiveAccountId is null) {
        <p class="text-gray-400 italic">Select an account on the Ledger tab to view its lifetime data.</p>
    } else if (_loading) {
        <div class="mt-8 flex flex-col items-center justify-center gap-2">
            <span class="p-0_5rem text-lg">Lifetime data is being compiled, please wait...</span>
            <img src="@ContentPaths.Asset("images/loading.gif")" alt="Loading..." class="xl-ico"/>
        </div>
    } else if (_data is null || _data.MissionCount == 0) {
        <NoDataFallback/>
    } else {
        <div class="flex flex-col md:flex-row md:items-stretch gap-0_75rem mt-0_75rem flex-1 min-h-0">
            <div class="filter-panel mt-0 @(_hideFilter ? "md:w-auto md:flex-none" : "md:w-[30%]")">
                <span class="mr-0_5rem h-20 font-bold text-gray-400">Filter</span>
                <button type="button" class="text-base toggle-link whitespace-nowrap" @onclick="@(() => _hideFilter = !_hideFilter)">
                    @(_hideFilter ? "Show" : "Hide")
                </button>
                @if (!_hideFilter) {
                    <MissionFilterBar FieldCtx="Config.FieldCtx"
                                      Applying="_applying"
                                      LastResultText="@_resultText"
                                      OnApply="ApplyFilterAsync"/>
                }
            </div>

            <div class="flex-1 flex flex-col min-h-0 px-2 overflow-auto shadow-sm bg-darkest rounded-md">
                <div class="flex items-center justify-between gap-2 pt-1">
                    <span class="ledger-underline text-base text-gray-400">Data compiled from @_data.MissionCount Missions</span>
                    @RenderOptionsPopover()
                </div>
                <div class="flex-1 min-h-0 py-1 overflow-auto block text-xs font-mono text-gray-300 text-center">
                    <DropDisplayContainer Artifacts="_data.Artifacts"
                                          Stones="_data.Stones"
                                          Ingredients="_data.Ingredients"
                                          StoneFragments="_data.StoneFragments"/>
                </div>
            </div>
        </div>
    }
</section>

@code {
    private const string KeySortMethod = "lifetime_sort_method";
    private bool _loading;
    private LifetimeData? _data;
    private LifetimeSortMethod _sortMethod = LifetimeSortMethod.Default;
    private bool _hideFilter;
    private bool _applying;
    private string _resultText = "";
    private MissionFilterMatcher? _matcher;
    private IReadOnlyList<DatabaseMission>? _allMissions;
    private Dictionary<string, List<MissionDrop>>? _allDropsCache;

    protected override async Task OnInitializedAsync() {
        Active.Changed += OnAccountChanged;
        AppState.Changed += OnAppStateChanged;
        var settings = await Settings.GetAllSettingsAsync();
        _sortMethod = LifetimeSorter.ParseMethod(
            settings.TryGetValue(KeySortMethod, out var s) ? s : null);
        await LoadAsync();
    }

    private void OnAccountChanged() {
        InvokeAsync(LoadAsync);
    }

    
    private void OnAppStateChanged() {
        if (AppState.PipelineState == Services.AppState.Success && Active.ActiveAccountId is not null) {
            DataCache.InvalidateAll();
            InvokeAsync(LoadAsync);
        }
    }

    private async Task LoadAsync() {
        var id = Active.ActiveAccountId;
        if (id is null) {
            _data = null;
            StateHasChanged();
            return;
        }

        var cached = DataCache.GetDrops(id, DateTime.UtcNow);
        Dictionary<string, List<MissionDrop>>? dropsByMission;
        if (cached is not null) {
            dropsByMission = cached;
        } else {
            _loading = true;
            StateHasChanged();
            dropsByMission = await Queries.GetAllPlayerDropsAsync(id);
            if (dropsByMission is not null) {
                DataCache.SetDrops(id, dropsByMission, DateTime.UtcNow);
            }

            _loading = false;
        }

        if (dropsByMission is null) {
            _data = null;
            StateHasChanged();
            return;
        }

        var cachedMissions = DataCache.GetMissions(id, DateTime.UtcNow);
        if (cachedMissions is not null) {
            _allMissions = cachedMissions;
        } else {
            var rows = await Queries.ViewMissionsOfEidAsync(id);
            var missions = rows?.Cast<DatabaseMission>().ToList() ?? new List<DatabaseMission>();
            DataCache.SetMissions(id, missions, DateTime.UtcNow);
            _allMissions = missions;
        }

        _allDropsCache = dropsByMission;
        _matcher = new MissionFilterMatcher(Config.DurationConfigs, id, DropsFetcher);

        var now = DateTime.UtcNow;
        var data = DataCache.GetLifetimeAggregate(id, now);
        if (data is null) {
            data = LifetimeAggregator.Aggregate(dropsByMission);
            DataCache.SetLifetimeAggregate(id, data, now);
        }
        LifetimeSorter.Sort(data, _sortMethod);
        _data = data;
        StateHasChanged();
    }

    private async Task<IReadOnlyList<MissionDrop>?> DropsFetcher(string accountId, string missionId) {
        return _allDropsCache is not null && _allDropsCache.TryGetValue(missionId, out var drops)
            ? drops
            : [];
    }

    private async Task ApplyFilterAsync(MissionFilterBar.LegacyFilter filter) {
        if (_allMissions is null || _matcher is null || _allDropsCache is null) {
            return;
        }

        _applying = true;
        StateHasChanged();

        var sw = Stopwatch.StartNew();
        var matchedIds = new HashSet<string>();
        foreach (var mission in _allMissions) {
            if (await _matcher.MissionMatchesFilterAsync(mission, filter.And, filter.Or)) {
                matchedIds.Add(mission.MissiondId);
            }
        }

        sw.Stop();

        var filteredDrops = new Dictionary<string, List<MissionDrop>>();
        foreach (var kvp in _allDropsCache) {
            if (matchedIds.Contains(kvp.Key)) {
                filteredDrops[kvp.Key] = kvp.Value;
            }
        }

        var data = LifetimeAggregator.Aggregate(filteredDrops);
        LifetimeSorter.Sort(data, _sortMethod);
        _data = data;

        var shown = matchedIds.Count;
        var filteredOut = _allMissions.Count - shown;
        _resultText = $"Filtered in {sw.Elapsed.TotalSeconds:0.###}s ({shown} shown, {filteredOut} filtered out)";
        _applying = false;
        StateHasChanged();
    }

    private RenderFragment RenderOptionsPopover() => __builder => {
        <OptionsPopover>
            <div>
                <span class="font-bold text-gray-400">Sort Method</span>
                <div class="tile-group mt-1">
                    <button type="button" class="tile-group-item @(_sortMethod == LifetimeSortMethod.Default ? "bg-darkest text-gray-200 border-gray-500" : "bg-darker text-gray-400 border-gray-700 hover:bg-dark_tab_hover")" @onclick="@(() => SetSortAsync(LifetimeSortMethod.Default))">Default</button>
                    <button type="button" class="tile-group-item @(_sortMethod == LifetimeSortMethod.Iv ? "bg-darkest text-gray-200 border-gray-500" : "bg-darker text-gray-400 border-gray-700 hover:bg-dark_tab_hover")" @onclick="@(() => SetSortAsync(LifetimeSortMethod.Iv))">Inventory Visualizer</button>
                    <button type="button" class="tile-group-item @(_sortMethod == LifetimeSortMethod.Count ? "bg-darkest text-gray-200 border-gray-500" : "bg-darker text-gray-400 border-gray-700 hover:bg-dark_tab_hover")" @onclick="@(() => SetSortAsync(LifetimeSortMethod.Count))">Total Count</button>
                    <button type="button" class="tile-group-item @(_sortMethod == LifetimeSortMethod.Random ? "bg-darkest text-gray-200 border-gray-500" : "bg-darker text-gray-400 border-gray-700 hover:bg-dark_tab_hover")" @onclick="@(() => SetSortAsync(LifetimeSortMethod.Random))">Random</button>
                </div>
            </div>
        </OptionsPopover>
    };

    private async Task SetSortAsync(LifetimeSortMethod method) {
        _sortMethod = method;
        await Settings.SetSettingAsync(KeySortMethod, LifetimeSorter.MethodString(method));
        if (_data is not null) {
            LifetimeSorter.Sort(_data, _sortMethod);
        }

        StateHasChanged();
    }

    public void Dispose() {
        Active.Changed -= OnAccountChanged;
        AppState.Changed -= OnAppStateChanged;
    }

}
