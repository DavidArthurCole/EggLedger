@page "/"
@using EggLedger.Domain.MissionQuery
@using EggLedger.Web.Components
@using EggLedger.Web.Data
@using EggLedger.Web.Services
@using EggLedger.Web.State
@implements IDisposable
@inject MissionQueryHandlers Queries
@inject FetchService Fetch
@inject AccountLoader Loader
@inject ActiveAccount Active
@inject AppStateService AppStateSvc

<PageTitle>EggLedger - Ledger</PageTitle>

<section class="view-layout overflow-hidden">
    <div class="flex flex-col items-center gap-2 py-2">
        <div class="text-xs text-gray-400 bg-darker border border-gray-700 rounded-lg px-4 py-2 text-center min-h-4">
            @if (_activeInfo is not null)
            {
                <span class="font-medium" style="color: #@_activeInfo.AccountColor">@_activeInfo.Nickname</span>
                <span class="text-gray-500 ml-1.5">@_activeInfo.EBString</span>
                @if (_activeInfo.SeString != "")
                {
                    <span class="text-gray-400 ml-1.5">&middot;</span>
                    <img src="@State.ContentPaths.Asset("images/soul_egg.png")" style="display:inline;height:1em;vertical-align:middle;margin:0 0.25em" alt="" />
                    <span style="color:#a855f7">@_activeInfo.SeString SE</span>
                    <span class="text-gray-400 ml-1.5">&middot;</span>
                    <img src="@State.ContentPaths.Asset("images/prophecy_egg.png")" style="display:inline;height:1em;vertical-align:middle;margin:0 0.25em" alt="" />
                    <span style="color:#eab308">@_activeInfo.PeCount PE</span>
                    @if (_activeInfo.TeCount > 0)
                    {
                        <span class="text-gray-400 ml-1.5">&middot;</span>
                        <img src="@State.ContentPaths.Asset("images/truth_egg.png")" style="display:inline;height:1em;vertical-align:middle;margin:0 0.25em" alt="" />
                        <span style="color:#c831ff">@_activeInfo.TeCount TE</span>
                    }
                }
            }
            else
            {
                <span class="text-gray-500 italic">Select an account from the top right to get started</span>
            }
        </div>

        <div class="flex gap-2">
            @if (_idle)
            {
                <button type="button" class="fetch-button" disabled="@(Active.ActiveAccountId is null)" @onclick="StartFetch">Fetch</button>
            }
            else
            {
                <button type="button" class="fetch-button" @onclick="StopFetch">Stop</button>
            }
            <button type="button" class="fetch-button w-auto" @onclick="OpenAddDialog">+ Add Account</button>
        </div>
    </div>

    @if (_progress is not null && !_idle || _terminalState is not null)
    {
        <div class="min-h-14 px-2 py-1 text-xs text-gray-500 bg-darkest rounded-md tabular-nums">
            @switch (_displayState)
            {
                case AppState.FetchingSave:
                    <div class="text-yellow-400">Fetching save...</div>
                    break;
                case AppState.FetchingMissions:
                    <div class="text-yellow-400">
                        Fetching missions...
                        @if (_progress?.MissionId is { Length: > 0 } mid)
                        {
                            <span class="text-gray-400 italic">@mid</span>
                        }
                    </div>
                    <div>
                        <span class="text-green-400">@(_progress?.Finished ?? 0)</span>
                        <span class="text-gray-400"> / @(_progress?.Total ?? 0) (@PercentText%)</span>
                    </div>
                    @if ((_progress?.Failed ?? 0) > 0 || (_progress?.Retried ?? 0) > 0)
                    {
                        <div>
                            @if ((_progress?.Failed ?? 0) > 0)
                            {
                                <span class="text-red-500">@_progress?.Failed failed</span>
                            }
                            @if ((_progress?.Failed ?? 0) > 0 && (_progress?.Retried ?? 0) > 0)
                            {
                                <span class="text-gray-400"> &middot; </span>
                            }
                            @if ((_progress?.Retried ?? 0) > 0)
                            {
                                <span class="text-orange-400">@_progress?.Retried to retry</span>
                            }
                        </div>
                    }
                    <div class="h-3 mt-1 rounded-sm overflow-hidden bg-dark">
                        <div class="h-full bg-green-500 transition-all duration-300 rounded-sm" style="width: @PercentText%"></div>
                    </div>
                    break;
                case AppState.ExportingData:
                    <div class="text-yellow-400">Exporting data...</div>
                    break;
                case AppState.Success:
                    <div class="text-green-400">Fetch complete.</div>
                    break;
                case AppState.Failed:
                    <div class="text-red-500">Data fetching failed. Please try again.</div>
                    break;
                case AppState.Interrupted:
                    <div class="text-yellow-400">Interrupted.</div>
                    break;
            }
        </div>
    }

    <div class="w-full max-w-2xl mx-auto flex flex-col gap-3">
        <AccountDataPanel Accounts="_existing" Changed="ReloadAsync" />
    </div>
</section>

<AddAccountDialog @ref="_addDialog" Added="OnAccountAdded" />

@code {
    private AddAccountDialog? _addDialog;
    private IReadOnlyList<DatabaseAccount> _existing = [];
    private AccountInfo? _activeInfo;

    private FetchProgress? _progress;
    private AppState? _terminalState;
    private CancellationTokenSource? _cts;

    private bool _idle => _terminalState is not null
        || _progress is null
        || _progress.State is AppState.AwaitingInput
            or AppState.Success or AppState.Failed or AppState.Interrupted;

    private AppState? _displayState => _terminalState ?? _progress?.State;

    private int Percent =>
        _progress is { Total: > 0 } p ? (int)Math.Round((double)p.Finished / p.Total * 100) : 0;

    private string PercentText => Percent.ToString();

    protected override async Task OnInitializedAsync()
    {
        Active.Changed += OnActiveChanged;
        await Loader.EnsureLoadedAsync();
        await ReloadAsync();
        RefreshActiveInfo();
    }

    private void OnActiveChanged()
    {
        RefreshActiveInfo();
        InvokeAsync(StateHasChanged);
    }

    private void RefreshActiveInfo() =>
        _activeInfo = Loader.Accounts.FirstOrDefault(a => a.Id == Active.ActiveAccountId);

    private async Task ReloadAsync()
    {
        await Loader.RefreshAsync();
        _existing = await Queries.GetExistingDataAsync();
        RefreshActiveInfo();
        StateHasChanged();
    }

    private async Task OpenAddDialog()
    {
        if (_addDialog is not null)
        {
            await _addDialog.OpenAsync();
        }
    }

    private async Task OnAccountAdded(AccountInfo account)
    {
        Active.SetActive(account.Id);
        await ReloadAsync();
        await StartFetch();
    }

    private async Task StartFetch()
    {
        var id = Active.ActiveAccountId;
        if (id is null)
        {
            return;
        }

        _terminalState = null;
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();

        var progress = new Progress<FetchProgress>(p =>
        {
            _progress = p;
            AppStateSvc.PipelineState = p.State;
            InvokeAsync(StateHasChanged);
        });

        try
        {
            var result = await Fetch.FetchPlayerDataAsync(id, progress, _cts.Token);
            _terminalState = result;
        }
        catch (Exception)
        {
            _terminalState = AppState.Failed;
        }

        AppStateSvc.PipelineState = _terminalState;
        await ReloadAsync();
    }

    private void StopFetch()
    {
        _cts?.Cancel();
    }

    public void Dispose()
    {
        Active.Changed -= OnActiveChanged;
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
