@page "/reports"
@using EggLedger.Domain.Reports
@using EggLedger.Web.Components.Reports
@using EggLedger.Web.Data
@using EggLedger.Web.State
@implements IDisposable
@inject ActiveAccount Active
@inject IndexedDbReportStore Store

<PageTitle>EggLedger - Reports</PageTitle>

<section class="view-layout overflow-hidden">
    @if (Active.ActiveAccountId is null)
    {
        <div class="flex-1 flex items-center justify-center">
            <p class="text-xs text-gray-500">Select an account on the Ledger tab to view its reports.</p>
        </div>
    }
    else
    {
        <div class="flex-1 min-h-0 bg-darkest rounded-md overflow-hidden flex flex-col">
            <div class="flex items-center gap-1.5 px-2 pt-1.5 pb-0 flex-shrink-0 flex-wrap">
                <button type="button"
                        class="text-sm px-4 py-1.5 rounded-full transition-colors @(_selectedGroup is null ? "bg-indigo-700 text-white" : "text-gray-400 hover:text-gray-200")"
                        @onclick="() => SelectGroup(null)">All</button>
                @foreach (var g in _groups)
                {
                    <div class="relative flex items-center">
                        <button type="button"
                                class="text-sm px-4 py-1.5 rounded-full transition-colors @(_selectedGroup == g.Id ? "bg-indigo-700 text-white" : "text-gray-400 hover:text-gray-200")"
                                @onclick="() => SelectGroup(g.Id)">@g.Name</button>
                        @if (_editMode)
                        {
                            <button type="button" class="text-gray-600 hover:text-red-400 text-sm" title="Delete group"
                                    @onclick:stopPropagation @onclick="() => DeleteGroupAsync(g.Id)">&#215;</button>
                        }
                    </div>
                }

                <div class="ml-auto flex items-center gap-1.5">
                    @if (_showNewGroup)
                    {
                        <input class="text-sm px-2 py-1 rounded bg-darker border border-gray-600 text-gray-200 focus:outline-none focus:border-blue-500 w-32"
                               type="text" placeholder="Group name" @bind="_newGroupName"
                               @bind:event="oninput" @onkeydown="GroupKeyDown" />
                        <button type="button" class="text-sm px-3 py-1.5 rounded border border-gray-700 text-gray-500 hover:text-gray-300" @onclick="CreateGroupAsync">Add</button>
                    }
                    else
                    {
                        <button type="button" class="text-sm px-3 py-1.5 rounded border border-gray-700 text-gray-500 hover:text-gray-300" @onclick="() => _showNewGroup = true">+ Group</button>
                    }
                    <button type="button"
                            class="text-sm px-3 py-1.5 rounded border @(_editMode ? "border-indigo-500 text-indigo-400" : "border-gray-700 text-gray-600 hover:text-gray-400")"
                            @onclick="() => _editMode = !_editMode">@(_editMode ? "Done" : "Edit")</button>
                    <button type="button" class="text-sm px-3 py-1.5 rounded border border-gray-700 text-gray-500 hover:text-gray-300" @onclick="OpenCreate">+ New Report</button>
                </div>
            </div>

            <ReportGrid @ref="_grid" AccountId="@Active.ActiveAccountId" GroupFilter="@_selectedGroup"
                        EditMode="_editMode" OnEdit="OpenEdit" />
        </div>
    }
</section>

<ReportBuilderPanel @ref="_builder" AccountId="@(Active.ActiveAccountId ?? "")"
                    GroupId="@_selectedGroup" Saved="OnSavedAsync" />

@code {
    private ReportGrid? _grid;
    private ReportBuilderPanel? _builder;
    private IReadOnlyList<ReportGroupRow> _groups = Array.Empty<ReportGroupRow>();
    private string? _selectedGroup;
    private bool _editMode;
    private bool _showNewGroup;
    private string _newGroupName = "";
    private string _loadedAccount = "";

    protected override void OnInitialized()
    {
        Active.Changed += OnActiveChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        var id = Active.ActiveAccountId;
        if (id is not null && id != _loadedAccount)
        {
            _loadedAccount = id;
            _selectedGroup = null;
            await LoadGroupsAsync();
        }
    }

    private void OnActiveChanged() => InvokeAsync(StateHasChanged);

    private async Task LoadGroupsAsync()
    {
        var id = Active.ActiveAccountId;
        if (id is null)
        {
            _groups = Array.Empty<ReportGroupRow>();
            return;
        }
        _groups = await Store.RetrieveAccountGroupsAsync(id);
        StateHasChanged();
    }

    private void SelectGroup(string? id) => _selectedGroup = id;

    private async Task OpenCreate()
    {
        if (_builder is not null)
        {
            await _builder.OpenForCreateAsync();
        }
    }

    private async Task OpenEdit(ReportDefinition def)
    {
        if (_builder is not null)
        {
            await _builder.OpenForEditAsync(def);
        }
    }

    private async Task OnSavedAsync()
    {
        if (_grid is not null)
        {
            await _grid.ReloadAsync();
        }
    }

    private async Task CreateGroupAsync()
    {
        var id = Active.ActiveAccountId;
        var name = _newGroupName.Trim();
        _showNewGroup = false;
        _newGroupName = "";
        if (id is null || string.IsNullOrEmpty(name))
        {
            return;
        }
        var groupId = await Store.InsertReportGroupAsync(new ReportGroupRow { AccountId = id, Name = name });
        await LoadGroupsAsync();
        _selectedGroup = groupId;
    }

    private async Task GroupKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await CreateGroupAsync();
        }
        else if (e.Key == "Escape")
        {
            _showNewGroup = false;
            _newGroupName = "";
        }
    }

    private async Task DeleteGroupAsync(string id)
    {
        await Store.DeleteReportGroupAsync(id);
        if (_selectedGroup == id)
        {
            _selectedGroup = null;
        }
        await LoadGroupsAsync();
        if (_grid is not null)
        {
            await _grid.ReloadAsync();
        }
    }

    public void Dispose()
    {
        Active.Changed -= OnActiveChanged;
    }
}
