@page "/settings"
@using EggLedger.Domain.MissionQuery
@using EggLedger.Web.Data
@using EggLedger.Web.Services
@using EggLedger.Web.Settings
@implements IDisposable
@inject IndexedDbSettings Settings
@inject IPlatformCapabilities Platform
@inject ScreenshotSafetyState ScreenshotSafety
@inject MissionQueryHandlers Queries
@inject FetchOrchestrator Fetch
@inject AccountLoader Loader

<PageTitle>EggLedger - Settings</PageTitle>

<div class="view-layout overflow-y-scroll">
    @if (!_loaded) {
        <p class="text-gray-500 italic mt-0_5rem">Loading settings...</p>
    } else {
        <div class="flex-1 min-h-0 px-3 py-2 overflow-auto shadow-sm block text-sm font-mono text-gray-400 bg-darkest rounded-md">
            @if (Platform.IsDesktop) {
                @* Desktop-only: window sizing and storage management need OS access. *@
                <WindowSettingsPanel Model="_model" OnSetting="OnSettingAsync"/>

                <hr class="mt-1rem mb-1rem w-full"/>

                <StorageSettingsPanel Model="_model" OnSetting="OnSettingAsync"/>

                <hr class="mt-1rem mb-1rem w-full"/>

                <div class="px-2 py-2 text-sm text-gray-400 bg-darker rounded-md tabular-nums overflow-auto">
                    <span class="mr-0_5rem font-bold text-lg text-gray-400 ledger-underline">Export Management</span><br/>
                    <ExportManagementPanel Model="_model" OnSetting="OnSettingAsync"/>
                </div>

                <hr class="mt-1rem mb-1rem w-full"/>
            }

            <OptionsPanel Model="_model" OnSetting="OnSettingAsync"/>

            <hr class="mt-1rem mb-1rem w-full"/>

            <CloudSyncPanel @ref="_cloudPanel"/>

            <hr class="mt-1rem mb-1rem w-full"/>

            <AccountDataPanel Accounts="_existing" Changed="ReloadAccountsAsync" Fetching="FetchingCardInfo"/>
        </div>
    }
</div>

@code {
    private bool _loaded;
    private readonly SettingsModel _model = new();
    private CloudSyncPanel? _cloudPanel;
    private IReadOnlyList<DatabaseAccount> _existing = [];

    
    private AccountDataPanel.FetchingCard? FetchingCardInfo =>
        !Fetch.IsIdle && Fetch.FetchingAccountId is { } id && Loader.Accounts.FirstOrDefault(a => a.Id == id) is { } info
            ? new AccountDataPanel.FetchingCard(id, info.Nickname, info.AccountColor, Fetch.Progress?.Finished ?? 0, Fetch.Progress?.Total ?? 0)
            : null;

    protected override async Task OnInitializedAsync() {
        var all = await Settings.GetAllSettingsAsync();
        _model.LoadFrom(all);
        _loaded = true;

        Fetch.Changed += OnFetchChanged;
        await Loader.EnsureLoadedAsync();
        await ReloadAccountsAsync();
    }

    private void OnFetchChanged() {
        InvokeAsync(StateHasChanged);
    }

    private async Task ReloadAccountsAsync() {
        _existing = await Queries.GetExistingDataAsync();
        StateHasChanged();
    }

    public void Dispose() {
        Fetch.Changed -= OnFetchChanged;
    }

    private async Task OnSettingAsync((string Key, string Value) change) {
        await Settings.SetSettingAsync(change.Key, change.Value);
        
        if (change.Key == SettingsModel.KeyScreenshotSafety) {
            ScreenshotSafety.Enabled = change.Value == "true";
        }

        
        if (_cloudPanel is not null && IsCloudSyncableKey(change.Key)) {
            await _cloudPanel.AutoSyncIfEnabledAsync();
        }

        StateHasChanged();
    }

    private static bool IsCloudSyncableKey(string key) {
        return key is
            SettingsModel.KeyAutoRefreshMenno or
            SettingsModel.KeyRetryFailedMissions or
            SettingsModel.KeyHideTimeoutErrors or
            SettingsModel.KeyWorkerCount or
            SettingsModel.KeyScreenshotSafety or
            SettingsModel.KeyShowMissionProgress or
            SettingsModel.KeyCollapseOlderSections or
            SettingsModel.KeyAdvancedDropFilter;
    }

}
