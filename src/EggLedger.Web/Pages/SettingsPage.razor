@page "/settings"
@using EggLedger.Web.Components
@using EggLedger.Web.Data
@using EggLedger.Web.Platform
@using EggLedger.Web.Settings
@using EggLedger.Web.State
@inject IndexedDbSettings Settings
@inject IPlatformCapabilities Platform
@inject ScreenshotSafetyState ScreenshotSafety

<PageTitle>EggLedger - Settings</PageTitle>

<div class="view-layout overflow-y-scroll">
    @if (!_loaded)
    {
        <p class="text-gray-500 italic mt-0_5rem">Loading settings...</p>
    }
    else
    {
        <div class="flex-1 min-h-0 px-3 py-2 overflow-auto shadow-sm block text-sm font-mono text-gray-400 bg-darkest rounded-md">
            @if (Platform.IsDesktop)
            {
                @* Desktop-only: window/browser sizing and storage management need real
                   OS access. Hidden in the browser build; a desktop host renders these. *@
                <div class="px-2 py-2 text-sm text-gray-400 bg-darker rounded-md tabular-nums overflow-auto">
                    <span class="mr-0_5rem font-bold text-lg text-gray-400 ledger-underline">Window &amp; Browser</span>
                    <span class="text-gray-500 text-xs italic ml-1">(effective on restart)</span><br />
                    <p class="mt-0_5rem text-gray-500 italic">Available in the desktop app.</p>
                </div>

                <hr class="mt-1rem mb-1rem w-full" />

                <div class="px-2 py-2 text-sm text-gray-400 bg-darker rounded-md tabular-nums overflow-auto">
                    <span class="mr-0_5rem font-bold text-lg text-gray-400 ledger-underline">Storage</span><br />
                    <p class="mt-0_5rem text-gray-500 italic">Available in the desktop app.</p>
                </div>

                <hr class="mt-1rem mb-1rem w-full" />
            }

            <OptionsPanel Model="_model" OnSetting="OnSettingAsync" />

            <hr class="mt-1rem mb-1rem w-full" />

            <CloudSyncPanel @ref="_cloudPanel" />
        </div>
    }
</div>

@code {
    private bool _loaded;
    private readonly SettingsModel _model = new();
    private CloudSyncPanel? _cloudPanel;

    protected override async Task OnInitializedAsync()
    {
        var all = await Settings.GetAllSettingsAsync();
        _model.LoadFrom(all);
        _loaded = true;
    }

    private async Task OnSettingAsync((string Key, string Value) change)
    {
        await Settings.SetSettingAsync(change.Key, change.Value);
        // Mask-EID toggle is shared app-wide; push it to the live state so every
        // EID on screen re-masks immediately without a reload.
        if (change.Key == SettingsModel.KeyScreenshotSafety)
        {
            ScreenshotSafety.Enabled = change.Value == "true";
        }
        // Auto-sync mirrors the Vue useCloudSync watch: a change to a cloud-syncable
        // setting triggers a push when auto-sync is on and a session is connected.
        // Machine-local keys (auto-export, worker-warning) do not.
        if (_cloudPanel is not null && IsCloudSyncableKey(change.Key))
        {
            await _cloudPanel.AutoSyncIfEnabledAsync();
        }
        StateHasChanged();
    }

    private static bool IsCloudSyncableKey(string key) => key is
        SettingsModel.KeyAutoRefreshMenno or
        SettingsModel.KeyRetryFailedMissions or
        SettingsModel.KeyHideTimeoutErrors or
        SettingsModel.KeyWorkerCount or
        SettingsModel.KeyScreenshotSafety or
        SettingsModel.KeyShowMissionProgress or
        SettingsModel.KeyCollapseOlderSections or
        SettingsModel.KeyAdvancedDropFilter;
}
