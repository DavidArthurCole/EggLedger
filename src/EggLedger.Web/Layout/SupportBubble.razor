@* Floating support bubble (mirrors the GitHub bubble). Hover reveals a card with the support
   rails + a link to the About page. Pure CSS hover; no circuit round-trip. *@

<div class="support-bubble-wrap">
  <button type="button" class="support-bubble" title="Support the project" aria-label="Support the project">
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21s-6.716-4.35-9.428-8.35C.86 9.9 1.5 6.5 4.2 5.3c1.9-.84 4.02-.16 5.3 1.36L12 9l2.5-2.34c1.28-1.52 3.4-2.2 5.3-1.36 2.7 1.2 3.34 4.6 1.628 7.35C18.716 16.65 12 21 12 21z"/></svg>
  </button>
  <div class="support-pop" role="dialog" aria-label="Support">
    <div class="support-pop-head">Support the project</div>
    <p class="support-pop-lede">Covers server and cert costs and keeps EggLedger free for everyone.</p>
    <div class="support-pop-rails">
      <a class="support-pop-rail" href="https://github.com/sponsors/DavidArthurCole" target="_blank" rel="noopener">GitHub Sponsors</a>
      <a class="support-pop-rail" href="https://patreon.com/DavidArthurCole" target="_blank" rel="noopener">Patreon</a>
      <a class="support-pop-rail" href="https://buymeacoffee.com/davidarthurcole" target="_blank" rel="noopener">Buy Me a Coffee</a>
    </div>
    <a class="support-pop-more" href="/about">More on the About page &rarr;</a>
  </div>
</div>
