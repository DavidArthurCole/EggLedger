@inherits LayoutComponentBase
@using EggLedger.Web.Components
@using EggLedger.Web.Services
@using EggLedger.Web.Settings
@using EggLedger.Web.State
@implements IDisposable
@inject AppStateService AppStateSvc
@inject ScreenshotSafetyState ScreenshotSafety
@inject EggLedger.Web.Data.IndexedDbSettings Settings
@inject AdminState AdminState
@inject AdminService Admin
@inject CloudSessionStore SessionStore

<div class="h-full flex flex-col space-y-3 pb-3 bg-darker">
    <TabBar Tabs="Tabs">
        <Right>
            <GlobalAccountHeader />
        </Right>
    </TabBar>

    <main class="flex-1 min-h-0 flex flex-col">
        @Body
    </main>

    <footer class="flex-shrink-0 text-center text-sm text-gray-500">
        <a class="url-link" href="https://github.com/DavidArthurCole/EggLedger" target="_blank" rel="noopener">EggLedger</a>@if (!string.IsNullOrEmpty(AppStateSvc.AppVersion))
        {<span> v@(AppStateSvc.AppVersion)</span>}
        <span> by @@<a class="url-link" href="https://github.com/fanaticscripter" target="_blank" rel="noopener">mk2</a>
        &amp; @@<a class="url-link" href="https://github.com/DavidArthurCole" target="_blank" rel="noopener">DavidArthurCole</a></span>
    </footer>
</div>

@code {
    private static readonly TabBar.TabItem[] _baseTabs =
    [
        new("Ledger", "/"),
        new("Mission Data", "/missions"),
        new("Lifetime Data", "/lifetime"),
        new("Reports", "/reports"),
        new("Settings", "/settings"),
        new("About", "/about"),
    ];

    private IReadOnlyList<TabBar.TabItem> Tabs =>
        AdminState.IsAdmin ? [.. _baseTabs, new("Admin", "/admin")] : _baseTabs;

    protected override async Task OnInitializedAsync() {
        AdminState.Changed += OnAdminChanged;
        AppStateSvc.AppVersion = AppVersionInfo.Current;

        // Seed the shared mask-EID toggle so masking components reflect it on first render.
        var settings = await Settings.GetAllSettingsAsync();
        if (settings.TryGetValue(SettingsModel.KeyScreenshotSafety, out var v))
            ScreenshotSafety.Enabled = v == "true";

        // Resolve admin status once so the Admin tab can appear without visiting it.
        var session = await SessionStore.GetSessionAsync();
        if (session?.Token is { } token)
            AdminState.IsAdmin = await Admin.IsAdminAsync(token);
    }

    private void OnAdminChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => AdminState.Changed -= OnAdminChanged;
}
