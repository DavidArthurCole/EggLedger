@using System.Globalization
@using EggLedger.Web.Server.Sync
@using Microsoft.AspNetCore.Components.Forms
@using SyncKit.Auth
@using SyncKit.Identity.AdminUi
@using SyncKit.Identity.Client
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Nav
@inject SessionCookieOptions SyncKitSession
@inject AppConfig Cfg
@inject IdentityApiClient Identity

@if (!string.IsNullOrEmpty(_sessionToken)) {
    <div class="px-2 py-2 text-sm text-gray-400 bg-darker rounded-md tabular-nums overflow-auto">
        <ProfilePanel SessionToken="@_sessionToken" ReturnUrl="@Nav.Uri">
            <AvatarTemplate Context="ctx">
                <div class="mt-0_5rem flex items-center gap-3">
                    @if (!string.IsNullOrEmpty(ctx.AvatarUrl)) {
                        <img class="w-14 h-14 rounded-full border border-gray-600" src="@ctx.AvatarUrl" alt="Profile picture"/>
                    } else {
                        <div class="w-14 h-14 rounded-full border border-gray-600 bg-darkest"></div>
                    }
                    <div class="flex flex-col gap-1">
                        <label class="ledger-btn apply-filter-button !mt-0 !mr-0 !ml-0 self-start cursor-pointer">
                            Upload picture
                            <InputFile class="hidden" OnChange="@ctx.OnFileSelected" accept="image/png,image/jpeg,image/webp"/>
                        </label>
                        <span class="text-gray-500 text-xs">PNG, JPEG, or WebP, up to 2 MB.</span>
                        @if (ctx.Error is not null) {
                            <span class="text-red-400 text-xs">@ctx.Error</span>
                        }
                    </div>
                </div>
            </AvatarTemplate>
            <ProvidersTemplate Context="ctx">
                @if (ctx.Banner is not null) {
                    <div class="mb-0_5rem text-xs text-gray-500">@ctx.Banner</div>
                }
                <table class="mt-0_5rem w-full text-sm border-collapse">
                    <tbody>
                    @foreach (var item in ctx.Items) {
                        <tr class="border-b border-gray-800 last:border-b-0">
                            <td class="py-1.5 pr-2 w-28">
                                <span class="flex items-center gap-1.5 font-medium text-gray-300">
                                    <img class="w-5 h-5 flex-shrink-0 object-contain" style="filter: brightness(0) invert(1);" src="@Abs(Identity.IconUrl(item.Provider))" alt=""/>
                                    @Cap(item.Provider)
                                </span>
                            </td>
                            @if (item.Identity is { } id) {
                                <td class="py-1.5 px-2 min-w-0">
                                    <span class="flex items-center gap-2 min-w-0">
                                        @if (!string.IsNullOrEmpty(id.Avatar)) {
                                            <button type="button" class="w-5 h-5 rounded-full flex-shrink-0 overflow-hidden border border-transparent hover:border-gray-500"
                                                    title="Use this picture" @onclick="item.OnSelectAvatar">
                                                <img class="w-full h-full object-cover" src="@id.Avatar" alt=""/>
                                            </button>
                                        }
                                        <span class="truncate text-gray-400">@(id.Username ?? id.Subject)</span>
                                        <span class="text-xs text-gray-600 flex-shrink-0">@id.LinkedAt.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)</span>
                                    </span>
                                </td>
                                <td class="py-1.5 pl-2 w-20 text-right">
                                    @if (item.CanUnlink) {
                                        <button type="button" class="text-xs px-2 py-1 rounded border border-red-900 bg-darker text-red-300 hover:bg-red-950"
                                                @onclick="item.OnUnlink">
                                            Unlink
                                        </button>
                                    } else {
                                        <span class="text-xs text-gray-600 italic" title="Cannot unlink the last login">Linked</span>
                                    }
                                </td>
                            } else {
                                <td class="py-1.5 px-2 text-gray-600 italic">Not linked</td>
                                <td class="py-1.5 pl-2 w-20 text-right">
                                    <a class="text-xs px-2 py-1 rounded border border-gray-700 bg-darker text-privacy_blue hover:bg-darkerthandark"
                                       href="@item.LinkUrl">
                                        Link
                                    </a>
                                </td>
                            }
                        </tr>
                    }
                    </tbody>
                </table>
            </ProvidersTemplate>
        </ProfilePanel>
    </div>
}

@code {
    private string _sessionToken = "";

    protected override void OnInitialized() {
        _sessionToken = HttpContextAccessor.HttpContext?.Request.Cookies[SyncKitSession.CookieName] ?? "";
    }

    private static string Cap(string s) {
        return string.IsNullOrEmpty(s) ? s : char.ToUpperInvariant(s[0]) + s[1..];
    }

    private string Abs(string url) {
        return url.StartsWith("http", StringComparison.Ordinal)
            ? url
            : $"{Cfg.IdentityWidgetUrl.TrimEnd('/')}/{url.TrimStart('/')}";
    }

}
