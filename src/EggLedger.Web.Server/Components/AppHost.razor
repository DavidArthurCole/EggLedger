@* Root document for the Blazor Server host. Identity flows into the circuit via cookie
   auth + the framework AuthenticationStateProvider. *@

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>EggLedger</title>
    <base href="/"/>

    <meta name="description" content="Track your Egg, Inc. space-mission history: fetch, filter, and export every artifact, ingredient, and stone you have ever pulled."/>
    <meta name="theme-color" content="#1f2937"/>
    <link rel="icon" type="image/png" href="_content/EggLedger.Web/images/icon-64.png"/>

    <meta property="og:type" content="website"/>
    <meta property="og:site_name" content="EggLedger"/>
    <meta property="og:title" content="EggLedger"/>
    <meta property="og:description" content="Track your Egg, Inc. space-mission history: fetch, filter, and export every artifact, ingredient, and stone you have ever pulled."/>
    <meta property="og:url" content="https://eggledger.davidarthurcole.me/"/>
    <meta property="og:image" content="https://eggledger.davidarthurcole.me/_content/EggLedger.Web/images/icon-64.png"/>

    <meta name="twitter:card" content="summary"/>
    <meta name="twitter:title" content="EggLedger"/>
    <meta name="twitter:description" content="Track your Egg, Inc. space-mission history: fetch, filter, and export every artifact, ingredient, and stone you have ever pulled."/>
    <meta name="twitter:image" content="https://eggledger.davidarthurcole.me/_content/EggLedger.Web/images/icon-64.png"/>

    <link rel="stylesheet" href="_content/EggLedger.Web/tailwind.css"/>
    <link rel="stylesheet" href="_content/EggLedger.Web/css/app.css"/>
    <link rel="stylesheet" href="EggLedger.Web.Server.styles.css"/>
    <style>
        /* Hidden until Blazor sets display:block on a circuit error (template default). */
        #blazor-error-ui { display: none; position: fixed; bottom: 0; left: 0; right: 0;
            background: #b91c1c; color: #fff; padding: 0.6rem 1rem; z-index: 1000; }
        #blazor-error-ui .reload, #blazor-error-ui .dismiss { color: #fff; margin-left: 0.75rem; cursor: pointer; }

        /* Reconnect overlay: blazor.web.js toggles the show/failed/rejected classes. */
        #components-reconnect-modal { display: none; }
        #components-reconnect-modal.components-reconnect-show,
        #components-reconnect-modal.components-reconnect-failed,
        #components-reconnect-modal.components-reconnect-rejected {
            display: flex; position: fixed; inset: 0; z-index: 1010;
            align-items: center; justify-content: center;
            background: rgba(0, 0, 0, 0.6); }
        .reconnect-card { background: #16181d; color: #d1d5db; border: 1px solid #4b5563;
            border-radius: 0.5rem; padding: 1.5rem 2rem; text-align: center;
            font-size: 0.9rem; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5); }
        .reconnect-spinner { width: 2rem; height: 2rem; margin: 0 auto 0.75rem;
            border: 3px solid #374151; border-top-color: #3b82f6; border-radius: 50%;
            animation: reconnect-spin 0.8s linear infinite; }
        @@keyframes reconnect-spin { to { transform: rotate(360deg); } }
        .reconnect-failed-text, .reconnect-rejected-text { display: none; }
        .components-reconnect-failed .reconnect-spinner,
        .components-reconnect-failed .reconnect-active-text,
        .components-reconnect-rejected .reconnect-spinner,
        .components-reconnect-rejected .reconnect-active-text { display: none; }
        .components-reconnect-failed .reconnect-failed-text,
        .components-reconnect-rejected .reconnect-rejected-text { display: block; }
        .reconnect-card a { color: #3b82f6; cursor: pointer; text-decoration: underline; }
    </style>
    <HeadOutlet @rendermode="@RenderMode"/>
</head>
<body>
<div id="app">
    <Routes @rendermode="@RenderMode"/>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&times;</span>
</div>

<div id="components-reconnect-modal">
    <div class="reconnect-card">
        <div class="reconnect-spinner"></div>
        <div class="reconnect-active-text">Reconnecting to the server...</div>
        <div class="reconnect-failed-text">
            Connection lost. <a onclick="window.Blazor.reconnect()">Retry</a> or <a href=".">reload</a>.
        </div>
        <div class="reconnect-rejected-text">
            Server updated. Reloading...
        </div>
    </div>
</div>
<script src="_content/EggLedger.Web/js/reportChartTooltip.js"></script>
<script src="_content/EggLedger.Web/js/outsideClick.js"></script>
<script src="_content/EggLedger.Web/js/beforeUnloadWarning.js"></script>
<script src="_framework/blazor.web.js"></script>
<script>
    // A rejected reconnect means the server-side circuit is gone (redeploy/restart); it can't
    // be resumed, so reload instead of asking the user to. Short delay so the message is seen.
    (function () {
        var modal = document.getElementById("components-reconnect-modal");
        if (!modal) return;
        var reloading = false;
        new MutationObserver(function () {
            if (reloading) return;
            if (modal.classList.contains("components-reconnect-rejected")) {
                reloading = true;
                setTimeout(function () { location.reload(); }, 2000);
            }
        }).observe(modal, { attributes: true, attributeFilter: ["class"] });
    })();
</script>
</body>
</html>

@code {

    // Prerender ON: storage is Postgres (no IndexedDB JS interop on init), so the old
    // prerender:false dodge is unneeded. Prerender gives interactive roots an SSR anchor;
    // without it the second root hit insertBefore parentNode null on batch 2.
    private static readonly InteractiveServerRenderMode RenderMode = new();
}
