@using EggLedger.Web
@using Microsoft.AspNetCore.Components.Web

@* Root document for the modern Blazor Server host. The RCL's App (a Router) renders
   with InteractiveServer + prerender:false so component init (which touches IndexedDB
   via JS interop) only runs once the circuit + JS are live. Identity flows into the circuit
   via cookie auth + the framework AuthenticationStateProvider. *@

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EggLedger</title>
    <base href="/" />

    <meta name="description" content="Track your Egg, Inc. space-mission history: fetch, filter, and export every artifact, ingredient, and stone you have ever pulled." />
    <meta name="theme-color" content="#1f2937" />
    <link rel="icon" type="image/png" href="_content/EggLedger.Web/images/icon-64.png" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="EggLedger" />
    <meta property="og:title" content="EggLedger" />
    <meta property="og:description" content="Track your Egg, Inc. space-mission history: fetch, filter, and export every artifact, ingredient, and stone you have ever pulled." />
    <meta property="og:url" content="https://eggledger.davidarthurcole.me/" />
    <meta property="og:image" content="https://eggledger.davidarthurcole.me/_content/EggLedger.Web/images/icon-64.png" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="EggLedger" />
    <meta name="twitter:description" content="Track your Egg, Inc. space-mission history: fetch, filter, and export every artifact, ingredient, and stone you have ever pulled." />
    <meta name="twitter:image" content="https://eggledger.davidarthurcole.me/_content/EggLedger.Web/images/icon-64.png" />

    <link rel="stylesheet" href="_content/EggLedger.Web/tailwind.css" />
    <link rel="stylesheet" href="_content/EggLedger.Web/css/app.css" />
    <HeadOutlet @rendermode="@RenderMode" />
</head>
<body>
    <div id="app">
        <Routes @rendermode="@RenderMode" />
    </div>

    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="." class="reload">Reload</a>
        <span class="dismiss">&times;</span>
    </div>
    <script src="_framework/blazor.web.js"></script>
</body>
</html>

@code {
    private static readonly Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode RenderMode = new(prerender: false);
}
