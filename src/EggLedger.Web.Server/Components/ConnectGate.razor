@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav

@* Shown to unauthenticated users. Starts the Discord OAuth: fetches the authorize URL
   and redirects. The callback signs the cookie-auth principal, and the circuit reconnects
   authenticated. *@
<div class="flex flex-col items-center justify-center gap-4 py-16 text-center">
    <h1 class="text-xl font-semibold text-gray-200">Connect your Discord account</h1>
    <p class="max-w-md text-sm text-gray-400">
        EggLedger stores your mission history on the server, scoped to your account.
        Connect with Discord to get started. Your data is private to you.
    </p>
    <button type="button" class="fetch-button w-auto" disabled="@_busy" @onclick="ConnectAsync">
        @(_busy ? "Connecting..." : "Connect with Discord")
    </button>
    @if (_error.Length > 0)
    {
        <p class="text-red-500 text-sm">@_error</p>
    }
</div>

@code {
    private bool _busy;
    private string _error = "";

    private sealed record InitResp(string Url, string State);

    private async Task ConnectAsync()
    {
        _busy = true;
        _error = "";
        try
        {
            var resp = await Http.GetFromJsonAsync<InitResp>("/api/v1/auth/discord");
            if (resp is { Url.Length: > 0 })
            {
                Nav.NavigateTo(resp.Url, forceLoad: true);
                return;
            }
            _error = "Could not start sign-in.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }
}
