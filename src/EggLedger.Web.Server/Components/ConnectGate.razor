@* Unauthenticated prompt. Fetches SyncKit's federated login sources and renders one native <a>
   per source (plain top-level navigation - SyncKit 0.6 redirect mode 302s back to this exact
   page with ?code, caught by LoginCallbackMiddleware). Falls back to the legacy Discord/
   Authentik anchors when Identity isn't configured or the source fetch fails. *@
@inject AppConfig Cfg
@inject NavigationManager Nav
@inject IdentityApiClient Identity
@using EggLedger.Web.Server.Sync
@using SyncKit.Contract
@using SyncKit.Identity.Client
@implements IDisposable
<div class="flex flex-col items-center justify-center gap-4 py-16 text-center">
    <h1 class="text-xl font-semibold text-gray-200">Connect your Discord account</h1>
    <p class="max-w-md text-sm text-gray-400">
        EggLedger stores your mission history on the server, scoped to your account.
        Connect with Discord to get started. Your data is private to you.
    </p>
    @if (_sources is { Count: > 0 }) {
        @foreach (var source in _sources) {
            <a class="discord-btn" href="@Abs(source.Url)">
                @if (source.Name == "Discord") {
                    <svg class="discord-icon" viewBox="0 0 127.14 96.36" fill="currentColor" aria-hidden="true">
                        <path d="M107.7 8.07A105.15 105.15 0 0 0 81.47 0a72.06 72.06 0 0 0-3.36 6.83 97.68 97.68 0 0 0-29.11 0A72.37 72.37 0 0 0 45.64 0a105.89 105.89 0 0 0-26.25 8.09C2.79 32.65-1.71 56.6.54 80.21a105.73 105.73 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.42 68.42 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.57 75.57 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.68 68.68 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.25 105.25 0 0 0 32.19-16.14c2.64-27.38-4.51-51.11-18.9-72.15ZM42.45 65.69C36.18 65.69 31 60 31 53s5-12.74 11.43-12.74S54 46 53.89 53s-5.05 12.69-11.44 12.69Zm42.24 0C78.41 65.69 73.25 60 73.25 53s5-12.74 11.44-12.74S96.23 46 96.12 53s-5.04 12.69-11.43 12.69Z"/>
                    </svg>
                }
                Connect with @source.Name
            </a>
        }
    } else if (!string.IsNullOrEmpty(Cfg.IdentityWidgetUrl) && !_sourcesFetchFailed) {
        <p class="text-sm text-gray-500">Loading login options...</p>
    } else {
        <a class="discord-btn" href="/api/v1/auth/login">
            <svg class="discord-icon" viewBox="0 0 127.14 96.36" fill="currentColor" aria-hidden="true">
                <path d="M107.7 8.07A105.15 105.15 0 0 0 81.47 0a72.06 72.06 0 0 0-3.36 6.83 97.68 97.68 0 0 0-29.11 0A72.37 72.37 0 0 0 45.64 0a105.89 105.89 0 0 0-26.25 8.09C2.79 32.65-1.71 56.6.54 80.21a105.73 105.73 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.42 68.42 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.57 75.57 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.68 68.68 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.25 105.25 0 0 0 32.19-16.14c2.64-27.38-4.51-51.11-18.9-72.15ZM42.45 65.69C36.18 65.69 31 60 31 53s5-12.74 11.43-12.74S54 46 53.89 53s-5.05 12.69-11.44 12.69Zm42.24 0C78.41 65.69 73.25 60 73.25 53s5-12.74 11.44-12.74S96.23 46 96.12 53s-5.04 12.69-11.43 12.69Z"/>
            </svg>
            Connect with Discord
        </a>
    }
    @if (!string.IsNullOrEmpty(Cfg.AuthentikAuthority)) {
        <a class="discord-btn" href="/api/v1/auth/authentik-login">
            Connect with Authentik
        </a>
    }
</div>

@code {
    private List<LoginSourceResponse>? _sources;
    private bool _sourcesFetchFailed;
    private readonly CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync() {
        if (string.IsNullOrEmpty(Cfg.IdentityWidgetUrl)) {
            return;
        }

        try {
            var response = await Identity.GetLoginSourcesAsync(Nav.Uri, "redirect", _cts.Token);
            _sources = response.Sources;
        }
        catch (HttpRequestException) {
            _sourcesFetchFailed = true;
        }
    }

    private string Abs(string url) {
        return url.StartsWith("http", StringComparison.Ordinal)
            ? url
            : $"{Cfg.IdentityWidgetUrl.TrimEnd('/')}/{url.TrimStart('/')}";
    }

    public void Dispose() {
        _cts.Cancel();
        _cts.Dispose();
    }

}
