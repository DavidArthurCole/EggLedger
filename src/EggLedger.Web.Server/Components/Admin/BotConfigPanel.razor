@using System.Globalization
@using System.Text.Json
@using EggLedger.Web.Components
@using EggLedger.Web.Server.Sync
@using SyncKit.Bot
@using SyncKit.Contract
@inject IServiceProvider Services
@inject AppConfig Config

<div class="admin-panel">
    <div class="admin-panel-head">
        <span class="admin-panel-title">Bot config</span>
    </div>

    @if (Service is null) {
        <p class="text-gray-500 italic text-sm">Bot not configured. Missing: @string.Join(", ", MissingConfig()).</p>
    } else if (!_loaded) {
        <p class="text-gray-500 italic text-sm">Loading...</p>
    } else {
        <div class="flex flex-col gap-2 mb-3 max-w-[520px]">
            <label class="text-xs text-gray-400">
                Dashboard channel ID
                <input class="rb-control w-full mt-1" @bind="_dashboardChannelId" placeholder="snowflake"/>
            </label>
            <label class="text-xs text-gray-400">
                GitHub feed thread ID
                <input class="rb-control w-full mt-1" @bind="_githubFeedThreadId" placeholder="snowflake (optional)"/>
            </label>
            <label class="text-xs text-gray-400">
                Deploy notifications thread ID
                <input class="rb-control w-full mt-1" @bind="_deployThreadId" placeholder="snowflake (unset = no deploy pings)"/>
            </label>
            @if (!string.IsNullOrEmpty(_githubWebhookUrl)) {
                <label class="text-xs text-gray-400">
                    GitHub webhook URL (read-only)
                    <input class="rb-control w-full mt-1 font-mono text-xs" value="@_githubWebhookUrl" readonly/>
                </label>
            }
        </div>

        <div class="admin-panel-head">
            <span class="admin-panel-title">Deploy-notification embeds</span>
            <OptionsPopover ButtonText="Variables">
                <table class="admin-table">
                    <tbody>
                    @foreach (var v in Service.Variables) {
                        <tr>
                            <td class="font-mono">@v.Name</td><td class="text-gray-500">@v.Desc</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </OptionsPopover>
        </div>

        <div class="tile-group mb-3">
            @foreach (var ev in Events) {
                <button type="button" class="tile-group-item @(_tab == ev.Key ? "bg-darkest text-gray-200 border-gray-500" : "bg-darker text-gray-400 border-gray-700 hover:bg-dark_tab_hover")" @onclick="@(() => _tab = ev.Key)">@ev.Label</button>
            }
        </div>

        <div class="admin-embed-row">
            <label class="admin-embed-field">
                Author icon URL
                <input class="rb-control w-full mt-1" @bind="Current.AuthorIconUrl"/>
            </label>
            <label class="admin-embed-field">
                Author name
                <input class="rb-control w-full mt-1" @bind="Current.AuthorName"/>
            </label>
            <label class="admin-embed-field">
                Author name URL
                <input class="rb-control w-full mt-1" @bind="Current.AuthorUrl"/>
            </label>
        </div>

        <div class="admin-embed-row">
            <span class="admin-embed-field">
                Color
                <div class="admin-color-swatch mt-1">
                    <input type="color" value="@ColorInputValue" @onchange="OnColorInput" title="Pick a color"/>
                    <input class="rb-control" style="width: 6rem" @bind="Current.ColorHex" placeholder="RRGGBB"/>
                </div>
            </span>
            <label class="admin-embed-field">
                Title
                <input class="rb-control w-full mt-1" @bind="Current.Title"/>
            </label>
            <label class="admin-embed-field">
                Title URL
                <input class="rb-control w-full mt-1" @bind="Current.TitleUrl"/>
            </label>
        </div>

        <label class="admin-embed-field block mb-2">
            Description
            <textarea class="rb-control w-full mt-1 font-mono text-xs" rows="2" @bind="Current.Description"></textarea>
        </label>

        <div class="admin-panel-head">
            <span class="text-xs font-bold text-gray-400">Fields (@Current.Fields.Count / 25)</span>
            <button type="button" class="ledger-btn" @onclick="@(() => AddField(Current))" disabled="@(Current.Fields.Count >= 25)">Add field</button>
        </div>
        @if (Current.Fields.Count == 0) {
            <p class="text-gray-500 text-xs">No fields.</p>
        }

        @foreach (var fld in Current.Fields) {
            <div class="admin-embed-row">
                <label class="admin-embed-field">
                    Name
                    <input class="rb-control w-full mt-1" @bind="fld.Name"/>
                </label>
                <label class="admin-embed-field">
                    Value
                    <input class="rb-control w-full mt-1" @bind="fld.Value"/>
                </label>
                <label class="text-xs text-gray-400 flex items-center gap-1">
                    <input type="checkbox" class="ext-opt-check" @bind="fld.Inline"/> Inline
                </label>
                <button type="button" class="text-red-400 hover:text-red-300 text-xs" @onclick="@(() => Current.Fields.Remove(fld))">Remove</button>
            </div>
        }

        <div class="admin-embed-row">
            <label class="admin-embed-field">
                Image URL
                <input class="rb-control w-full mt-1" @bind="Current.ImageUrl"/>
            </label>
            <label class="admin-embed-field">
                Thumbnail URL
                <input class="rb-control w-full mt-1" @bind="Current.ThumbnailUrl"/>
            </label>
        </div>

        <div class="admin-embed-row items-center">
            <label class="admin-embed-field">
                Footer
                <input class="rb-control w-full mt-1" @bind="Current.FooterText"/>
            </label>
            <label class="admin-embed-field">
                Footer icon URL
                <input class="rb-control w-full mt-1" @bind="Current.FooterIconUrl"/>
            </label>
            <label class="text-xs text-gray-400 flex items-center gap-1">
                <input type="checkbox" class="ext-opt-check" @bind="Current.Timestamp"/> Timestamp
            </label>
        </div>

        <div class="flex gap-2 mt-3">
            <button type="button" class="ledger-btn" @onclick="Save" disabled="@_saving">@(_saving ? "Saving..." : "Save")</button>
            <button type="button" class="ledger-btn" @onclick="@(() => ResetTab(_tab))" disabled="@_saving">Reset this event to default</button>
        </div>
        @if (_msg is not null) {
            <p class="text-xs mt-2 @(_error ? "text-red-400" : "text-gray-500")">@_msg</p>
        }
    }
</div>

@code {
    private static readonly JsonSerializerOptions JsonOpts = new(JsonSerializerDefaults.Web);

    private static readonly (string Key, string Label)[] Events =
        [("success", "Success"), ("failure", "Failure"), ("uptodate", "Already up to date")];

    private BotConfigService? Service => Services.GetService<BotConfigService>();

    private List<string> MissingConfig() {
        var missing = new List<string>();
        if (string.IsNullOrEmpty(Config.BotToken)) missing.Add("DISCORD_BOT_TOKEN");
        if (string.IsNullOrEmpty(Config.GuildId)) missing.Add("DISCORD_GUILD_ID");
        if (string.IsNullOrEmpty(Config.DatabaseUrl)) missing.Add("DATABASE_URL");
        if (string.IsNullOrEmpty(Config.DashboardChannelId)) missing.Add("DISCORD_DASHBOARD_CHANNEL_ID");
        return missing.Count > 0 ? missing : ["bot guild membership not yet resolved, retry shortly"];
    }

    private bool _loaded;
    private bool _saving;
    private bool _error;
    private string? _msg;
    private string _tab = "success";

    private string ColorInputValue {
        get {
            var h = (Current.ColorHex ?? "").TrimStart('#');
            return h.Length == 6 && uint.TryParse(h, NumberStyles.HexNumber, null, out _) ? $"#{h.ToUpperInvariant()}" : "#5865F2";
        }
    }

    private void OnColorInput(ChangeEventArgs e) {
        Current.ColorHex = (e.Value?.ToString() ?? "").TrimStart('#').ToUpperInvariant();
    }

    private string _dashboardChannelId = "";
    private string _githubFeedThreadId = "";
    private string _deployThreadId = "";
    private string _githubWebhookUrl = "";

    private EmbedForm _success = new();
    private EmbedForm _failure = new();
    private EmbedForm _uptodate = new();

    private EmbedForm Form(string key) {
        return key switch { "failure" => _failure, "uptodate" => _uptodate, _ => _success };
    }

    private EmbedForm Current => Form(_tab);

    protected override async Task OnInitializedAsync() {
        if (Service is null) return;
        var v = await Service.GetAsync(CancellationToken.None);
        _dashboardChannelId = v.DashboardChannelId ?? "";
        _githubFeedThreadId = v.GithubFeedThreadId ?? "";
        _deployThreadId = v.DeployNotificationsThreadId ?? "";
        _githubWebhookUrl = v.GithubWebhookUrl ?? "";
        _success = Seed(v.SuccessEmbedJson, v.DefaultSuccess);
        _failure = Seed(v.FailureEmbedJson, v.DefaultFailure);
        _uptodate = Seed(v.UptodateEmbedJson, v.DefaultUptodate);
        _loaded = true;
    }

    private static EmbedForm Seed(string? savedJson, EmbedSpec fallback) {
        if (!string.IsNullOrWhiteSpace(savedJson)) {
            try {
                return EmbedForm.From(JsonSerializer.Deserialize<EmbedSpec>(savedJson, JsonOpts)!);
            }
            catch (JsonException) {
            }
        }

        return EmbedForm.From(fallback);
    }

    private void ResetTab(string key) {
        if (Service is null) return;
        var def = key switch { "failure" => Service.DefaultFailure, "uptodate" => Service.DefaultAlreadyUpToDate, _ => Service.DefaultSuccess };
        var seeded = EmbedForm.From(def);
        switch (key) {
            case "failure": _failure = seeded; break;
            case "uptodate": _uptodate = seeded; break;
            default: _success = seeded; break;
        }
    }

    private static void AddField(EmbedForm f) {
        if (f.Fields.Count < 25) f.Fields.Add(new FieldForm());
    }

    private async Task Save() {
        if (Service is null) return;
        _saving = true;
        _msg = null;
        _error = false;
        try {
            var input = new BotConfigInput(
                _dashboardChannelId.Trim(),
                _githubFeedThreadId.Trim(),
                _deployThreadId.Trim(),
                ToJson(_success),
                ToJson(_failure),
                ToJson(_uptodate));
            var result = await Service.SaveAsync(input, CancellationToken.None);
            if (result.Ok) {
                _githubWebhookUrl = result.GithubWebhookUrl ?? _githubWebhookUrl;
                _msg = "Saved.";
            } else {
                _error = true;
                _msg = $"Save failed: {result.Error}";
            }
        }
        catch (Exception ex) {
            _error = true;
            _msg = ex.Message;
        }
        finally {
            _saving = false;
        }
    }

    private static string ToJson(EmbedForm f) {
        return JsonSerializer.Serialize(f.ToSpec(), JsonOpts);
    }

    private sealed class FieldForm {
        public string Name { get; set; } = "";
        public string Value { get; set; } = "";
        public bool Inline { get; set; }
    }

    private sealed class EmbedForm {
        public string ColorHex { get; set; } = "";
        public string AuthorName { get; set; } = "";
        public string AuthorUrl { get; set; } = "";
        public string AuthorIconUrl { get; set; } = "";
        public string Title { get; set; } = "";
        public string TitleUrl { get; set; } = "";
        public string Description { get; set; } = "";
        public List<FieldForm> Fields { get; set; } = [];
        public string ImageUrl { get; set; } = "";
        public string ThumbnailUrl { get; set; } = "";
        public string FooterText { get; set; } = "";
        public string FooterIconUrl { get; set; } = "";
        public bool Timestamp { get; set; }

        public static EmbedForm From(EmbedSpec s) {
            return new EmbedForm {
                ColorHex = s.Color is { } c ? c.ToString("X6") : "",
                AuthorName = s.AuthorName ?? "",
                AuthorUrl = s.AuthorUrl ?? "",
                AuthorIconUrl = s.AuthorIconUrl ?? "",
                Title = s.Title ?? "",
                TitleUrl = s.TitleUrl ?? "",
                Description = s.Description ?? "",
                Fields = (s.Fields ?? []).Select(x => new FieldForm { Name = x.Name, Value = x.Value, Inline = x.Inline }).ToList(),
                ImageUrl = s.ImageUrl ?? "",
                ThumbnailUrl = s.ThumbnailUrl ?? "",
                FooterText = s.FooterText ?? "",
                FooterIconUrl = s.FooterIconUrl ?? "",
                Timestamp = s.Timestamp
            };
        }

        public EmbedSpec ToSpec() {
            return new EmbedSpec(
                ParseColor(ColorHex),
                NullIfBlank(AuthorName), NullIfBlank(AuthorUrl), NullIfBlank(AuthorIconUrl),
                NullIfBlank(Title), NullIfBlank(TitleUrl), NullIfBlank(Description),
                Fields.Where(x => !string.IsNullOrWhiteSpace(x.Name) || !string.IsNullOrWhiteSpace(x.Value))
                    .Select(x => new EmbedFieldSpec(x.Name, x.Value, x.Inline)).ToList(),
                NullIfBlank(ImageUrl), NullIfBlank(ThumbnailUrl),
                NullIfBlank(FooterText), NullIfBlank(FooterIconUrl),
                Timestamp);
        }

        private static uint? ParseColor(string hex) {
            return uint.TryParse(hex.TrimStart('#'), NumberStyles.HexNumber, null, out var v) ? v : null;
        }

        private static string? NullIfBlank(string s) {
            return string.IsNullOrWhiteSpace(s) ? null : s;
        }
    }

}
