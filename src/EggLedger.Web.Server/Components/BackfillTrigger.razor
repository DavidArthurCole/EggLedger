@using EggLedger.Web.Server.Storage
@inject IServiceProvider Services

@* Runs the first-login backfill once per authenticated circuit, renders nothing. Resolved
   optionally: in dev / no-DB there is no backfill service, so this is a no-op. *@

@code {
    protected override async Task OnInitializedAsync()
    {
        if (Services.GetService(typeof(FirstLoginBackfill)) is FirstLoginBackfill backfill)
        {
            // Never block the UI on backfill; manual restore stays available.
            try { await backfill.RunIfNeededAsync(); }
            catch { }
        }
    }
}
