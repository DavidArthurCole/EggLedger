<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>EggLedger shared domain: ei protobuf types, eiafx config, mission packing/query, export, reports math. Pure, host-agnostic. Validated vs the Go reference via golden fixtures.</Description>
    <IsPackable>true</IsPackable>
    <PackageId>EggLedger.Domain</PackageId>
    <Version>0.1.0-local.1</Version>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="protobuf-net" Version="3.2.45" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\**\*" />
  </ItemGroup>

</Project>
